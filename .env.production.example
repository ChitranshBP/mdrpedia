# MDRPedia — Production Environment Variables
# Copy to .env and fill in values

# PostgreSQL connection with connection pooling params
# connection_limit: max connections per Prisma Client instance
# pool_timeout: seconds to wait for a connection from the pool
# statement_timeout: max query execution time in ms
DATABASE_URL="postgresql://user:password@host:5432/mdrpedia?connection_limit=10&pool_timeout=20&statement_timeout=30000"

# Direct URL for migrations (bypasses connection pooler like PgBouncer)
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/mdrpedia"

# Admin authentication
ADMIN_API_KEY="your-secure-admin-key"

# IP hashing salt for privacy-preserving analytics
IP_HASH_SALT="your-random-salt"

# Cloudinary (for image hosting)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional: OpenAlex API for enrichment
OPENALEX_EMAIL=""
