<script define:vars={{ slug, doctorFullName: doctor.fullName, doctorSpecialty: doctor.specialty, doctorTier: doctor.tier, doctorPortrait: doctor.portraitUrl || '' }}>
    // Save to recently viewed in localStorage
    try {
        const STORAGE_KEY = 'mdrpedia_recently_viewed';
        const MAX_ITEMS = 8;
        const raw = localStorage.getItem(STORAGE_KEY);
        const existing = raw ? JSON.parse(raw) : [];
        const filtered = existing.filter(p => p.slug !== slug);
        filtered.unshift({
            slug,
            fullName: doctorFullName,
            specialty: doctorSpecialty,
            tier: doctorTier,
            portraitUrl: doctorPortrait || undefined,
            viewedAt: Date.now(),
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(filtered.slice(0, MAX_ITEMS)));
    } catch {}
</script>

