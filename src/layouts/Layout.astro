---
/**
 * MDRPedia 2.0 — Base Layout
 * Editorial / scholarly design. Paper-light primary.
 */
import "../styles/global.css";
import GlobalSearchModal from "../components/GlobalSearchModal";
import NewsletterSignup from "../components/NewsletterSignup.astro";

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	tier?: string;
	robots?: string;
}

const {
	title,
	description = "MDRPedia — The Physicians' Register. An independently-verified encyclopedia of physicians worldwide. Also known as MDpedia and DRpedia.",
	ogImage,
	tier,
	robots,
} = Astro.props;
const canonicalURL = new URL(
	Astro.url.pathname,
	Astro.site ?? "https://mdrpedia.com",
);

const currentPath = Astro.url.pathname;

const navLinks = [
	{ key: "home", label: "Home", href: "/" },
	{ key: "doctors", label: "Doctors", href: "/doctors" },
	{ key: "specialties", label: "Specialties", href: "/specialty" },
	{ key: "institutions", label: "Institutions", href: "/institutions" },
	{ key: "rankings", label: "Rankings", href: "/rankings" },
	{ key: "ethics", label: "Ethical Doctors", href: "/ethical-doctors" },
	{ key: "news", label: "News", href: "/news" },
	{ key: "about", label: "About", href: "/about" },
];

function getActiveKey(path: string): string {
	if (path === "/") return "home";
	if (path.startsWith("/doctors")) return "doctors";
	if (path.startsWith("/specialty")) return "specialties";
	if (path.startsWith("/institutions")) return "institutions";
	if (path.startsWith("/rankings")) return "rankings";
	if (path.startsWith("/ethical")) return "ethics";
	if (path.startsWith("/news")) return "news";
	if (path.startsWith("/about")) return "about";
	return "";
}

const activeKey = getActiveKey(currentPath);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="robots" content={robots || "index, follow"} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
		<link rel="preconnect" href="https://logo.clearbit.com" />
		<link rel="dns-prefetch" href="https://pubmed.ncbi.nlm.nih.gov" />

		<!-- Fonts: preloaded for better LCP (replaces CSS @import) -->
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&family=Inter+Tight:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&family=Inter+Tight:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&family=Inter+Tight:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" /></noscript>

		<link rel="prefetch" href="/doctors" />
		<link rel="prefetch" href="/rankings" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:site_name" content="MDRPedia" />
		<meta property="og:image" content={ogImage || `${canonicalURL.origin}/og-default.png`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage || `${canonicalURL.origin}/og-default.png`} />
		<meta name="twitter:site" content="@mdrpedia" />

		<link rel="canonical" href={canonicalURL.href} />
		<!-- hreflang: x-default for future i18n; signals this is the primary language version -->
		<link rel="alternate" hreflang="x-default" href={canonicalURL.href} />
		<link rel="alternate" hreflang="en" href={canonicalURL.href} />
		<link rel="alternate" type="application/rss+xml" title="MDRPedia News Feed" href="/feed.xml" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Organization Schema with alternate names -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "MDRPedia",
			"alternateName": ["MDpedia", "DRpedia", "MD Pedia", "DR Pedia", "MDR Pedia"],
			"url": "https://mdrpedia.com",
			"sameAs": [
				"https://mdpedia.com",
				"https://drpedia.com",
				"https://twitter.com/mdrpedia"
			],
			"description": "The world's first independently-verified encyclopedia of physicians, ranking medical professionals by human impact. Known as MDpedia in the West and DRpedia in the East.",
			"foundingDate": "2024",
			"logo": {
				"@type": "ImageObject",
				"url": "https://mdrpedia.com/favicon.svg"
			}
		})} />

		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content={tier === "TITAN" ? "#FCFBF7" : "#f5f3ee"} />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="MDRPedia" />
		<link rel="apple-touch-icon" href="/icons/icon-192.png" />

		<title>{title}</title>
	</head>
	<body class={tier === "TITAN" ? "titan-theme" : ""}>
		<a href="#main-content" class="skip-link">Skip to main content</a>

		<!-- Regional Welcome Banner -->
		<div id="regional-banner" class="regional-banner" hidden>
			<div class="container regional-banner__inner">
				<span id="regional-banner-text"></span>
				<a id="regional-banner-link" href="/about/mdpedia">Learn more</a>
				<button id="regional-banner-close" class="regional-banner__close" type="button" aria-label="Dismiss banner">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
				</button>
			</div>
		</div>

		<!-- Navigation -->
		<nav class="chrome-nav" aria-label="Primary navigation">
			<div class="container chrome-nav__inner">
				<a href="/" class="mdr-logo" aria-label="MDRPedia home">
					<svg class="mdr-logo__mark" width="32" height="32" viewBox="0 0 48 48" aria-hidden="true">
						<circle class="ring" cx="24" cy="24" r="22.5" stroke="currentColor" stroke-width="1.2" fill="none" />
						<circle class="ring" cx="24" cy="24" r="19" stroke="currentColor" stroke-width="1" fill="none" stroke-dasharray="1 3" />
						<path d="M10 30 Q8 22 12 14" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M10.5 28 Q8.5 28 7.5 26.5" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M10 25 Q8 25 7.2 23.5" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M10 22 Q8 22 7.5 20.5" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M10.5 19 Q9 18.5 9 17" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M38 30 Q40 22 36 14" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M37.5 28 Q39.5 28 40.5 26.5" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M38 25 Q40 25 40.8 23.5" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M38 22 Q40 22 40.5 20.5" stroke="currentColor" stroke-width="1" fill="none" />
						<path d="M37.5 19 Q39 18.5 39 17" stroke="currentColor" stroke-width="1" fill="none" />
						<text x="24" y="30" text-anchor="middle" fill="currentColor" font-family="'Source Serif 4', serif" font-size="20" font-weight="500">M</text>
					</svg>
					<span>
						<span class="mdr-logo__text">MDR<em>Pedia</em></span>
						<span class="mdr-logo__est">The Physicians' Register</span>
					</span>
				</a>
				<div class="chrome-nav__links">
					{navLinks.map(link => (
						<a href={link.href} class={activeKey === link.key ? "active" : ""}>{link.label}</a>
					))}
				</div>
				<div class="chrome-nav__actions">
					<button id="search-trigger" class="chrome-nav__search" type="button" aria-label="Search the register">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
						<span>Search the register...</span>
						<kbd>&#8984;K</kbd>
					</button>
					<a href="/doctor/claim" class="chrome-nav__cta">Nominate</a>
					<button id="mobile-menu-btn" class="chrome-nav__burger" type="button" aria-label="Open navigation menu" aria-expanded="false">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
					</button>
				</div>
			</div>
		</nav>

		<!-- Mobile Navigation Drawer -->
		<div id="mobile-nav-drawer" class="mobile-nav-drawer" aria-hidden="true">
			<div class="mobile-nav-drawer__backdrop"></div>
			<nav class="mobile-nav-drawer__panel" aria-label="Mobile navigation">
				<div class="mobile-nav-drawer__header">
					<span class="mdr-logo__text">MDR<em>Pedia</em></span>
					<button id="mobile-menu-close" class="mobile-nav-drawer__close" type="button" aria-label="Close navigation menu">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
					</button>
				</div>
				<div class="mobile-nav-drawer__links">
					{navLinks.map(link => (
						<a href={link.href} class={activeKey === link.key ? "active" : ""}>{link.label}</a>
					))}
				</div>
				<div class="mobile-nav-drawer__footer">
					<a href="/doctor/claim" class="chrome-nav__cta mobile-nav-drawer__cta">Nominate a Physician</a>
				</div>
			</nav>
		</div>

		<main id="main-content">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="chrome-foot">
			<div class="container">
				<div class="chrome-foot__grid">
					<div class="chrome-foot__col">
						<a href="/" class="mdr-logo chrome-foot__logo" aria-label="MDRPedia home">
							<svg class="mdr-logo__mark" width="40" height="40" viewBox="0 0 48 48" aria-hidden="true">
								<circle cx="24" cy="24" r="22.5" stroke="currentColor" stroke-width="1.2" fill="none" />
								<circle cx="24" cy="24" r="19" stroke="currentColor" stroke-width="1" fill="none" stroke-dasharray="1 3" />
								<path d="M10 30 Q8 22 12 14" stroke="currentColor" stroke-width="1" fill="none" />
								<path d="M38 30 Q40 22 36 14" stroke="currentColor" stroke-width="1" fill="none" />
								<text x="24" y="30" text-anchor="middle" fill="currentColor" font-family="'Source Serif 4', serif" font-size="20" font-weight="500">M</text>
							</svg>
							<span>
								<span class="mdr-logo__text">MDR<em>Pedia</em></span>
								<span class="mdr-logo__est">The Physicians' Register &middot; Est. 2024</span>
							</span>
						</a>
						<p class="chrome-foot__tagline">
							An open, independently-verified register of the physicians who shape medicine — and those who practice it with integrity.
						</p>
					</div>
					<div class="chrome-foot__col">
						<h5>Register</h5>
						<a href="/doctors">Browse Profiles</a>
						<a href="/rankings">Rankings</a>
						<a href="/specialty">Specialties</a>
						<a href="/institutions">Institutions</a>
						<a href="/rare-diseases">Rare Diseases</a>
						<a href="/clinical-trials">Clinical Trials</a>
					</div>
					<div class="chrome-foot__col">
						<h5>Ethics</h5>
						<a href="/ethical-doctors">Ethical Doctors</a>
						<a href="/doctor/claim">Nominate</a>
						<a href="/prizes">Medical Awards</a>
						<a href="/news">News</a>
					</div>
					<div class="chrome-foot__col">
						<h5>About</h5>
						<a href="/about">Methodology</a>
						<a href="/about">Editorial Board</a>
						<a href="/about">Data Sources</a>
						<a href="/contact">Contact</a>
					</div>
					<div class="chrome-foot__col">
						<h5>System</h5>
						<a href="/about">Open Data</a>
						<a href="/privacy">Privacy</a>
						<a href="/terms">Terms</a>
						<a href="/communities">Communities</a>
					</div>
				</div>
				<div class="chrome-foot__newsletter">
					<NewsletterSignup source="footer" />
				</div>
				<div class="chrome-foot__also-known">
					Also known as <a href="/about/mdpedia">MDpedia</a> in the West and <a href="/about/drpedia">DRpedia</a> in the East
				</div>
				<div class="chrome-foot__bottom">
					<span class="mono">MDRPEDIA &middot; REG. 2024 &middot; OPEN ENCYCLOPEDIA &middot; CC-BY-SA 4.0</span>
					<span class="mono">v2.0 &middot; VERIFIED-LEDGER</span>
				</div>
			</div>
		</footer>

		<!-- Global Search Modal -->
		<GlobalSearchModal client:load />

		<!-- Service Worker Registration -->
		<script>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js')
						.then(reg => console.log('SW registered:', reg.scope))
						.catch(err => console.log('SW registration failed:', err));
				});
			}
		</script>

		<!-- Regional Banner Script -->
		<script>
			(function() {
				if (sessionStorage.getItem('banner-dismissed')) return;
				const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
				const eastern = ['Asia/', 'Africa/', 'Indian/', 'Pacific/Auckland'].some(p => tz.startsWith(p))
					|| ['Asia', 'Africa', 'Indian'].some(p => tz.includes(p));
				const link = eastern ? '/about/drpedia' : '/about/mdpedia';
				const banner = document.getElementById('regional-banner');
				const text = document.getElementById('regional-banner-text');
				const linkEl = document.getElementById('regional-banner-link') as HTMLAnchorElement | null;
				const closeBtn = document.getElementById('regional-banner-close');
				if (banner && text && linkEl) {
					text.textContent = eastern
						? 'You may know us as DRpedia — same register, same verified profiles.'
						: 'You may know us as MDpedia — same register, same verified profiles.';
					linkEl.href = link;
					banner.hidden = false;
				}
				closeBtn?.addEventListener('click', () => {
					if (banner) banner.hidden = true;
					sessionStorage.setItem('banner-dismissed', '1');
				});
			})();
		</script>

		<!-- Search Trigger + Mobile Nav Script -->
		<script>
			document.getElementById('search-trigger')?.addEventListener('click', () => {
				const event = new KeyboardEvent('keydown', {
					key: 'k',
					code: 'KeyK',
					metaKey: true,
					ctrlKey: false,
					bubbles: true
				});
				document.dispatchEvent(event);
			});

			// Mobile navigation drawer
			const menuBtn = document.getElementById('mobile-menu-btn');
			const closeBtn = document.getElementById('mobile-menu-close');
			const drawer = document.getElementById('mobile-nav-drawer');
			const backdrop = drawer?.querySelector('.mobile-nav-drawer__backdrop');

			function openDrawer() {
				drawer?.classList.add('open');
				drawer?.setAttribute('aria-hidden', 'false');
				menuBtn?.setAttribute('aria-expanded', 'true');
				document.body.style.overflow = 'hidden';
			}

			function closeDrawer() {
				drawer?.classList.remove('open');
				drawer?.setAttribute('aria-hidden', 'true');
				menuBtn?.setAttribute('aria-expanded', 'false');
				document.body.style.overflow = '';
			}

			menuBtn?.addEventListener('click', openDrawer);
			closeBtn?.addEventListener('click', closeDrawer);
			backdrop?.addEventListener('click', closeDrawer);

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape' && drawer?.classList.contains('open')) closeDrawer();
			});
		</script>
	</body>
</html>

<style>
	/* ── Skip Link ── */
	.skip-link {
		position: absolute; top: -100%; left: 16px; z-index: 999;
		padding: 12px 24px; background: var(--ink); color: var(--paper);
		font-weight: 600; border-radius: var(--r-3); text-decoration: none;
		transition: top 0.2s;
	}
	.skip-link:focus { top: 12px; }

	/* ── Regional Banner ── */
	.regional-banner {
		background: var(--ink-blue-2, #eef3ff); border-bottom: 1px solid var(--rule);
		font-size: 13px; color: var(--ink-2);
	}
	.regional-banner__inner {
		display: flex; align-items: center; justify-content: center;
		gap: 12px; padding: 8px 16px;
	}
	.regional-banner__inner a {
		color: var(--ink-blue); font-weight: 500; text-decoration: underline;
		text-underline-offset: 2px;
	}
	.regional-banner__close {
		padding: 4px; background: none; border: none; color: var(--ink-3);
		cursor: pointer; border-radius: var(--r-1); margin-left: 4px;
	}
	.regional-banner__close:hover { color: var(--ink); background: var(--paper-2); }

	/* ── Logo Mark ── */
	.mdr-logo { display: inline-flex; align-items: center; gap: 10px; color: var(--ink); text-decoration: none; }
	.mdr-logo__mark { display: block; }
	.mdr-logo__text { font-family: var(--font-serif); font-size: 22px; font-weight: 500; letter-spacing: -0.01em; line-height: 1; }
	.mdr-logo__text em { font-style: italic; font-weight: 400; color: var(--ink-2); }
	.mdr-logo__est { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.18em; color: var(--ink-3); text-transform: uppercase; margin-top: 3px; display: block; }

	/* ── Top nav ── */
	.chrome-nav {
		position: sticky; top: 0; z-index: 100;
		background: color-mix(in oklch, var(--paper) 92%, transparent);
		backdrop-filter: saturate(1.2) blur(8px);
		-webkit-backdrop-filter: saturate(1.2) blur(8px);
		border-bottom: 1px solid var(--rule);
	}
	.chrome-nav__inner {
		display: flex; align-items: center; justify-content: space-between;
		height: 68px;
	}
	.chrome-nav__links { display: flex; align-items: center; gap: 28px; }
	.chrome-nav__links a {
		font-family: var(--font-sans); font-size: 14px; font-weight: 500;
		color: var(--ink-2); text-decoration: none; letter-spacing: -0.005em;
		transition: color var(--t-fast) var(--ease);
	}
	.chrome-nav__links a:hover { color: var(--ink); }
	.chrome-nav__links a.active { color: var(--ink); position: relative; }
	.chrome-nav__links a.active::after {
		content: ""; position: absolute; left: 0; right: 0; bottom: -22px;
		height: 2px; background: var(--ink);
	}
	.chrome-nav__cta {
		display: inline-flex; align-items: center; gap: 6px;
		padding: 8px 14px; border: 1px solid var(--ink); color: var(--ink);
		font-family: var(--font-sans); font-size: 13px; font-weight: 500;
		text-decoration: none; border-radius: var(--r-2);
		transition: background var(--t-fast) var(--ease), color var(--t-fast) var(--ease);
	}
	.chrome-nav__cta:hover { background: var(--ink); color: var(--paper); }
	.chrome-nav__search {
		display: inline-flex; align-items: center; gap: 10px;
		padding: 7px 10px 7px 12px;
		background: var(--paper-2); border: 1px solid var(--rule);
		border-radius: var(--r-2); color: var(--ink-3);
		font-size: 13px; min-width: 200px; cursor: pointer;
		font-family: var(--font-sans);
	}
	.chrome-nav__search kbd {
		font-family: var(--font-mono); font-size: 10px; padding: 2px 5px;
		background: var(--paper); border: 1px solid var(--rule); border-radius: 3px;
		color: var(--ink-3);
	}

	/* ── Footer ── */
	.chrome-foot {
		margin-top: var(--s-10);
		border-top: 1px solid var(--rule);
		padding: var(--s-8) 0 var(--s-7);
		background: var(--paper-2);
	}
	.chrome-foot__grid { display: grid; grid-template-columns: 1.2fr 1fr 1fr 1fr 1fr; gap: var(--s-6); }
	.chrome-foot__col h5 {
		font-family: var(--font-sans); font-size: 11px; font-weight: 600;
		letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3);
		margin-bottom: var(--s-3);
	}
	.chrome-foot__col a {
		display: block; font-size: 13px; color: var(--ink-2);
		text-decoration: none; padding: 4px 0;
	}
	.chrome-foot__col a:hover { color: var(--ink); text-decoration: underline; }
	.chrome-foot__newsletter {
		margin-top: var(--s-6);
		max-width: 480px;
	}
	.chrome-foot__also-known {
		margin-top: var(--s-5); padding-top: var(--s-4);
		text-align: center;
		font-family: var(--font-sans); font-size: 12px; color: var(--ink-3);
		font-style: italic;
	}
	.chrome-foot__also-known a {
		color: var(--ink-2); text-decoration: underline;
		text-underline-offset: 2px;
	}
	.chrome-foot__also-known a:hover { color: var(--ink); }
	.chrome-foot__bottom {
		margin-top: var(--s-4); padding-top: var(--s-5);
		border-top: 1px solid var(--rule);
