---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
    const newsEntries = await getCollection("news");
    return newsEntries.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { title, summary, date, category, source, url, content } = entry.data;

// Get all news for related articles
const allNews = await getCollection("news");
// Prefer same-category articles, then fill with recent ones
const sameCategoryArticles = allNews
    .filter(n => n.id !== entry.id && n.data.category === category)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const otherArticles = allNews
    .filter(n => n.id !== entry.id && n.data.category !== category)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const relatedArticles = [...sameCategoryArticles, ...otherArticles].slice(0, 3);

// SVG icon paths (matching news.astro design language)
const ICON_PATHS: Record<string, string> = {
    'flask': 'M9 3h6v2H9V3zm0 4v6l-3 6h12l-3-6V7H9z',
    'pill': 'M10.5 1.5a4.5 4.5 0 0 0-4.5 4.5v12a4.5 4.5 0 0 0 9 0V6a4.5 4.5 0 0 0-4.5-4.5zM8 12h5',
    'trophy': 'M6 9H4.5a2.5 2.5 0 0 1 0-5H6m12 5h1.5a2.5 2.5 0 0 0 0-5H18M6 9a6 6 0 0 0 12 0V4H6v5zm3 12h6m-3-3v3',
    'lightbulb': 'M9 21h6m-3-3v3M12 3a6 6 0 0 0-4 10.5V17h8v-3.5A6 6 0 0 0 12 3z',
    'clipboard': 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2M9 5h6',
    'tool': 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z',
    'globe': 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z',
    'dna': 'M2 15c6.667-6 13.333 0 20-6M2 9c6.667 6 13.333 0 20 6M9 3v18m6-18v18',
    'zap': 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
    'file': 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8',
};

// Category definitions
const CATEGORIES: Record<string, { icon: string; color: string; label: string }> = {
    'breakthrough': { icon: 'flask', color: '#ffd700', label: 'Research Breakthrough' },
    'clinical-trial': { icon: 'pill', color: '#00aaff', label: 'Clinical Trial' },
    'award': { icon: 'trophy', color: '#a78bfa', label: 'Award & Recognition' },
    'achievement': { icon: 'trophy', color: '#a78bfa', label: 'Achievement' },
    'impact': { icon: 'lightbulb', color: '#10b981', label: 'Impact Story' },
    'registry': { icon: 'clipboard', color: '#f59e0b', label: 'Registry Update' },
    'technique': { icon: 'tool', color: '#ec4899', label: 'New Technique' },
    'global-health': { icon: 'globe', color: '#06b6d4', label: 'Global Health' },
    'research': { icon: 'dna', color: '#8b5cf6', label: 'Research' },
    'innovation': { icon: 'zap', color: '#22d3ee', label: 'Innovation' },
    'default': { icon: 'file', color: '#888', label: 'News' }
};

function getCategoryInfo(category: string) {
    const normalized = category.toLowerCase().replace(/\s+/g, '-');
    return CATEGORIES[normalized] || CATEGORIES['default'];
}

const catInfo = getCategoryInfo(category);

function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
}

function formatShortDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
    });
}

function getReadingTime(text: string) {
    const wordsPerMinute = 200;
    const words = (text || '').split(/\s+/).length + (summary || '').split(/\s+/).length;
    const minutes = Math.ceil(words / wordsPerMinute);
    return minutes < 1 ? '1 min read' : `${minutes} min read`;
}

function _getRelativeTime(dateStr: string) {
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

    if (diffDays === 0) return 'Today';
    if (diffDays === 1) return 'Yesterday';
    if (diffDays < 7) return `${diffDays} days ago`;
    if (diffDays < 30) return `${Math.floor(diffDays / 7)} weeks ago`;
    return formatDate(dateStr);
}

const shareUrl = `https://mdrpedia.com/news/${entry.id}`;
const shareText = encodeURIComponent(title);

// NewsArticle JSON-LD for SEO
const newsArticleSchema = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": title,
    "description": summary,
    "datePublished": date,
    "dateModified": date,
    "author": {
        "@type": "Organization",
        "name": "MDRPedia Editorial",
        "url": "https://mdrpedia.com"
    },
    "publisher": {
        "@type": "Organization",
        "name": "MDRPedia",
        "url": "https://mdrpedia.com",
        "logo": {
            "@type": "ImageObject",
            "url": "https://mdrpedia.com/og-default.png"
        }
    },
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": shareUrl
    },
    "image": "https://mdrpedia.com/og-default.png",
    "articleSection": category,
    "wordCount": ((content || '').split(/\s+/).length + (summary || '').split(/\s+/).length),
    ...(source && { "citation": { "@type": "CreativeWork", "name": source, ...(url && { "url": url }) } })
};

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mdrpedia.com" },
        { "@type": "ListItem", "position": 2, "name": "News", "item": "https://mdrpedia.com/news" },
        { "@type": "ListItem", "position": 3, "name": title }
    ]
};
---

<Layout title={`${title} — MDRPedia News`} description={summary}>
    <script type="application/ld+json" set:html={JSON.stringify(newsArticleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <div class="article-page">
        <div class="container">
            <!-- Breadcrumb -->
            <nav class="breadcrumb">
                <a href="/news" class="breadcrumb-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    <span>Back to News</span>
                </a>
            </nav>

            <article class="article-container">
                <!-- Article Header -->
                <header class="article-header">
                    <div class="header-glow"></div>

                    <div class="article-meta">
                        <div class="category-badge" style={`--cat-color: ${catInfo.color}`}>
                            <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d={ICON_PATHS[catInfo.icon]} />
                            </svg>
                            {catInfo.label}
                        </div>
                        <span class="meta-divider">•</span>
                        <div class="meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                <line x1="16" y1="2" x2="16" y2="6"/>
                                <line x1="8" y1="2" x2="8" y2="6"/>
                                <line x1="3" y1="10" x2="21" y2="10"/>
                            </svg>
                            <time datetime={date}>{formatDate(date)}</time>
                        </div>
                        <span class="meta-divider">•</span>
                        <div class="meta-item">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                            <span>{getReadingTime(content || '')}</span>
                        </div>
                    </div>

                    <h1 class="article-title">{title}</h1>

                    <div class="article-source">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                        <span>Source:</span>
                        <strong>{source}</strong>
                        {url && (
                            <a href={url} target="_blank" rel="noopener noreferrer" class="source-link">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                                    <polyline points="15 3 21 3 21 9"/>
                                    <line x1="10" y1="14" x2="21" y2="3"/>
                                </svg>
                                View Original
                            </a>
                        )}
                    </div>
                </header>

                <!-- Hero Visual -->
                <div class="article-hero" style={`--cat-color: ${catInfo.color}`}>
                    <div class="hero-content">
                        <div class="hero-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d={ICON_PATHS[catInfo.icon]} />
                            </svg>
                        </div>
                        <div class="hero-label">{catInfo.label}</div>
                    </div>
                    <div class="hero-pattern"></div>
                    <div class="hero-shimmer"></div>
                </div>

                <!-- Article Content -->
                <section class="article-content">
                    <p class="lead-text">{summary}</p>

                    <div class="content-divider">
                        <span></span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                            <path d="M2 17l10 5 10-5"/>
                            <path d="M2 12l10 5 10-5"/>
                        </svg>
                        <span></span>
                    </div>

                    <div class="body-text">
                        {content ? (
                            content.split('\n\n').map((paragraph: string) => (
                                <p>{paragraph}</p>
                            ))
                        ) : (
                            <div class="pending-content">
                                <div class="pending-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/>
                                        <polyline points="12 6 12 12 16 14"/>
                                    </svg>
                                </div>
                                <h4>Full Report Coming Soon</h4>
                                <p>Our editorial team is preparing an in-depth analysis of this story. Check back soon for the complete coverage.</p>
                            </div>
                        )}
                    </div>
                </section>

                <!-- Share Section -->
                <div class="share-section">
                    <div class="share-label">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="18" cy="5" r="3"/>
                            <circle cx="6" cy="12" r="3"/>
                            <circle cx="18" cy="19" r="3"/>
                            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                        </svg>
                        Share this article
                    </div>
                    <div class="share-buttons">
                        <a
                            href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="share-btn twitter"
                            aria-label="Share on Twitter"
                        >
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                            </svg>
                        </a>
                        <a
                            href={`https://www.linkedin.com/shareArticle?mini=true&url=${shareUrl}&title=${shareText}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="share-btn linkedin"
                            aria-label="Share on LinkedIn"
                        >
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                            </svg>
                        </a>
                        <button class="share-btn copy" id="copy-link" aria-label="Copy link">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Article Footer -->
                <footer class="article-footer">
                    <div class="footer-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <polyline points="9 12 12 15 16 10"/>
                        </svg>
                        <span>MDRPedia Verified Source</span>
                    </div>
                    <p class="footer-text">
                        This article has been reviewed and verified by the MDRPedia editorial team.
                        For corrections or updates, please contact our newsroom.
                    </p>
                </footer>
            </article>

            <!-- Related Articles -->
            {relatedArticles.length > 0 && (
                <section class="related-section">
                    <h2 class="related-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/>
                        </svg>
                        Related Articles
                    </h2>
                    <div class="related-grid">
                        {relatedArticles.map((article) => {
                            const relCatInfo = getCategoryInfo(article.data.category);
                            return (
                                <a href={`/news/${article.id}`} class="related-card" style={`--cat-color: ${relCatInfo.color}`}>
                                    <div class="related-highlight"></div>
                                    <div class="related-category">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d={ICON_PATHS[relCatInfo.icon]} />
                                        </svg>
                                        {relCatInfo.label}
                                    </div>
                                    <h3 class="related-card-title">{article.data.title}</h3>
                                    <div class="related-meta">
                                        <span>{formatShortDate(article.data.date)}</span>
                                        <span class="related-source">{article.data.source}</span>
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                </section>
            )}

            <!-- Back to News CTA -->
            <div class="back-cta">
                <a href="/news" class="back-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"/>
                        <rect x="14" y="3" width="7" height="7"/>
                        <rect x="14" y="14" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/>
                    </svg>
                    <span>Browse All Articles</span>
                </a>
            </div>
        </div>
    </div>
</Layout>

<script>
    const copyBtn = document.getElementById('copy-link');

    copyBtn?.addEventListener('click', async () => {
        try {
            await navigator.clipboard.writeText(window.location.href);
            copyBtn.classList.add('copied');
            setTimeout(() => copyBtn.classList.remove('copied'), 2000);
        } catch (err) {
            console.error('Failed to copy:', err);
        }
    });
</script>

<style>
    .article-page {
        min-height: 100vh;
    }

    .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 20px 100px;
    }

    /* Breadcrumb */
    .breadcrumb {
        margin-bottom: 32px;
    }

    .breadcrumb-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-pill);
        color: var(--ink-2);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all var(--t-fast) var(--ease);
    }

    .breadcrumb-link svg {
        width: 16px;
        height: 16px;
        transition: transform var(--t-fast);
    }

    .breadcrumb-link:hover {
        background: var(--ink-blue-2);
        border-color: var(--ink-blue);
        color: var(--ink-blue);
    }

    .breadcrumb-link:hover svg {
        transform: translateX(-4px);
    }

    /* Article Container */
    .article-container {
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        overflow: hidden;
        box-shadow: var(--shadow-3);
    }

    /* Article Header */
    .article-header {
        padding: 48px 48px 32px;
        border-bottom: 1px solid var(--rule);
        position: relative;
    }

    .header-glow { display: none; }

    .article-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 24px;
    }

    .category-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-pill);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ink-2);
    }

    .badge-icon {
        width: 14px;
        height: 14px;
        color: var(--cat-color);
    }

    .meta-divider {
        color: var(--rule);
        font-size: 0.8rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.85rem;
        color: var(--ink-3);
    }

    .meta-item svg {
        width: 14px;
        height: 14px;
        opacity: 0.6;
    }

    .article-title {
        font-family: var(--font-serif);
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 500;
        line-height: 1.2;
        color: var(--ink);
        margin-bottom: 24px;
        letter-spacing: -0.02em;
    }

    .article-source {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        color: var(--ink-3);
        font-size: 0.95rem;
    }

    .article-source svg {
        width: 16px;
        height: 16px;
        opacity: 0.6;
    }

    .article-source strong {
        color: var(--ink-2);
    }

    .source-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 12px;
        background: var(--ink-blue-2);
        border: 1px solid var(--ink-blue);
        border-radius: var(--r-pill);
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--ink-blue);
        text-decoration: none;
        transition: all var(--t-fast);
        margin-left: 8px;
    }

    .source-link svg {
        width: 12px;
        height: 12px;
        opacity: 1;
    }

    .source-link:hover {
        background: color-mix(in oklch, var(--ink-blue) 20%, transparent);
    }

    /* Article Hero */
    .article-hero {
        width: 100%;
        height: 280px;
        background: var(--paper-2);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-content {
        text-align: center;
        z-index: 1;
    }

    .hero-icon {
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    .hero-icon svg {
        width: 64px;
        height: 64px;
        color: var(--cat-color);
    }

    .hero-label {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--ink-3);
    }

    .hero-pattern,
    .hero-shimmer { display: none; }

    /* Article Content */
    .article-content {
        padding: 48px;
    }

    .lead-text {
        font-family: var(--font-serif);
        font-size: 1.3rem;
        line-height: 1.7;
        color: var(--ink-2);
        font-weight: 400;
        margin-bottom: 32px;
    }

    .content-divider {
        display: flex;
        align-items: center;
        gap: 16px;
        margin: 32px 0;
    }

    .content-divider span {
        flex: 1;
        height: 1px;
        background: var(--rule);
    }

    .content-divider svg {
        width: 20px;
        height: 20px;
        color: var(--ink-3);
        opacity: 0.4;
    }

    .body-text {
        font-size: 1.1rem;
        line-height: 1.85;
        color: var(--ink-2);
    }

    .body-text p {
        margin-bottom: 1.5rem;
    }

    .body-text p:last-child {
        margin-bottom: 0;
    }

    /* Pending Content */
    .pending-content {
        text-align: center;
        padding: 3rem 2rem;
        background: var(--paper-2);
        border: 1px dashed var(--rule);
        border-radius: var(--r-4);
    }

    .pending-icon {
        width: 60px;
        height: 60px;
        margin: 0 auto 1.25rem;
        display: flex;
