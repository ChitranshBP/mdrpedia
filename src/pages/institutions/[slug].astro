---
/**
 * MDRPedia — Institution Profile Page
 * Display institution details and affiliated doctors
 * Includes Medical Knowledge Graph schema for AI crawlers
 */
import Layout from "../../layouts/Layout.astro";
import { prisma } from "../../lib/prisma";
import { generateHospitalPageSchema } from "../../lib/medical-knowledge-graph";
import { getInstitutionLogo, getInstitutionInitials, getInstitutionColor } from "../../lib/institution-logos";

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/institutions");

// Fetch institution with all related data
let institution = null;
let dbError = false;

try {
    institution = await prisma.hospital.findUnique({
        where: { slug },
        include: {
            geography: true,
            affiliations: {
                include: {
                    profile: {
                        select: {
                            id: true,
                            slug: true,
                            full_name: true,
                            specialty: true,
                            tier: true,
                            h_index: true,
                            portrait_url: true
                        }
                    }
                },
                orderBy: {
                    profile: { h_index: 'desc' }
                }
            }
        }
    });
} catch (e) {
    console.error('Institution page database error:', e);
    dbError = true;
}

if (!institution) {
    return Astro.redirect("/institutions?error=not_found");
}

// Process doctors by tier
const doctors = institution.affiliations
    .filter(aff => aff.profile)
    .map(aff => ({
        ...aff.profile,
        role: aff.role,
        department: aff.department,
        isPrimary: aff.is_primary
    }));

const tierCounts = { TITAN: 0, ELITE: 0, MASTER: 0, UNRANKED: 0 };
doctors.forEach(d => {
    if (d.tier) tierCounts[d.tier]++;
});

// Get unique specialties
const specialties = [...new Set(doctors.map(d => d.specialty).filter(Boolean))];

const sectorLabels: Record<string, string> = {
    PUBLIC: 'Public Institution',
    PRIVATE: 'Private Institution'
};

const tierColors: Record<string, string> = {
    TITAN: 'var(--titan-text)',
    ELITE: 'var(--elite-text)',
    MASTER: 'var(--master-text)',
    UNRANKED: 'var(--ink-3)'
};

// Generate Hospital Knowledge Graph Schema
const hospitalSchema = generateHospitalPageSchema(
    {
        hospitalName: institution.name,
        slug: institution.slug,
        hospitalUrl: institution.website || undefined,
        sector: institution.sector as 'PUBLIC' | 'PRIVATE',
        centerOfExcellence: institution.center_of_excellence || undefined,
        description: institution.description || undefined,
        logoUrl: institution.logo_url || undefined,
        geography: institution.geography ? {
            country: institution.geography.country,
            region: institution.geography.region || undefined,
            city: institution.geography.city || undefined,
        } : undefined,
    },
    doctors.map(d => ({
        fullName: d.full_name || '',
        slug: d.slug || '',
        specialty: d.specialty || '',
        tier: d.tier || 'UNRANKED',
    }))
);

// Dataset schema describing the hospital's physician roster
const hospitalDatasetSchema = {
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: `${institution.name} - Affiliated Physicians`,
    description: `Complete roster of ${doctors.length} verified physicians affiliated with ${institution.name}, including ${tierCounts.TITAN} Titans, ${tierCounts.ELITE} Elite, and ${tierCounts.MASTER} Masters.`,
    keywords: [
        institution.name,
        ...specialties.slice(0, 10),
        institution.geography?.country,
        institution.geography?.city,
        'hospital',
        'medical institution',
        'physicians',
    ].filter(Boolean).join(', '),
    variableMeasured: [
        { '@type': 'PropertyValue', name: 'Total Physicians', value: doctors.length },
        { '@type': 'PropertyValue', name: 'Titan Tier', value: tierCounts.TITAN },
        { '@type': 'PropertyValue', name: 'Elite Tier', value: tierCounts.ELITE },
        { '@type': 'PropertyValue', name: 'Master Tier', value: tierCounts.MASTER },
        { '@type': 'PropertyValue', name: 'Specialties', value: specialties.length },
    ],
    creator: {
        '@type': 'Organization',
        name: 'MDRPedia',
        url: 'https://mdrpedia.com',
    },
    isAccessibleForFree: true,
};
---

<Layout title={`${institution.name} — MDRPedia`}>
    <!-- Hospital Knowledge Graph Schema -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify(hospitalSchema, null, 2)}
    />

    <!-- Hospital Dataset Schema -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify(hospitalDatasetSchema, null, 2)}
    />

    <div class="container institution-profile">
        <!-- Hero Section -->
        <header class="inst-hero">
            <div class="hero-content">
                <div class="hero-logo">
                    {(() => {
                        const logoUrl = institution.logo_url || getInstitutionLogo(institution.name, institution.website);
                        const initials = getInstitutionInitials(institution.name);
                        const color = getInstitutionColor(institution.name);
                        return logoUrl ? (
                            <>
                                <img
                                    src={logoUrl}
                                    alt={institution.name}
                                    loading="eager"
                                    onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
                                />
                                <div class="logo-placeholder" style={`display:none;background:${color}`}>
                                    {initials}
                                </div>
                            </>
                        ) : (
                            <div class="logo-placeholder" style={`background:${color}`}>
                                {initials}
                            </div>
                        );
                    })()}
                </div>
                <div class="hero-text">
                    <h1>{institution.name}</h1>
                    <p class="location">
                        {institution.geography?.city && `${institution.geography.city}, `}
                        {institution.geography?.region && `${institution.geography.region}, `}
                        {institution.geography?.country || 'Unknown Location'}
                    </p>
                    <div class="hero-badges">
                        <span class={`sector-badge sector-${institution.sector.toLowerCase()}`}>
                            {sectorLabels[institution.sector]}
                        </span>
                        {institution.ranking_position && (
                            <span class="ranking-badge">
                                Ranked #{institution.ranking_position}
                                {institution.ranking_source && ` (${institution.ranking_source})`}
                            </span>
                        )}
                        {institution.center_of_excellence && (
                            <span class="coe-badge">
                                Center of Excellence: {institution.center_of_excellence}
                            </span>
                        )}
                    </div>
                </div>
            </div>
        </header>

        <!-- Stats Bar -->
        <div class="stats-bar">
            <div class="stat-item">
                <span class="stat-value">{doctors.length}</span>
                <span class="stat-label">Affiliated Doctors</span>
            </div>
            <div class="stat-item" style={`--stat-color: ${tierColors.TITAN}`}>
                <span class="stat-value">{tierCounts.TITAN}</span>
                <span class="stat-label">Titans</span>
            </div>
            <div class="stat-item" style={`--stat-color: ${tierColors.ELITE}`}>
                <span class="stat-value">{tierCounts.ELITE}</span>
                <span class="stat-label">Elite</span>
            </div>
            <div class="stat-item" style={`--stat-color: ${tierColors.MASTER}`}>
                <span class="stat-value">{tierCounts.MASTER}</span>
                <span class="stat-label">Masters</span>
            </div>
            <div class="stat-item">
                <span class="stat-value">{specialties.length}</span>
                <span class="stat-label">Specialties</span>
            </div>
        </div>

        <div class="content-grid">
            <!-- Main Content -->
            <main class="main-content">
                <!-- About Section -->
                {institution.description && (
                    <section class="content-section">
                        <h2>About</h2>
                        <p>{institution.description}</p>
                    </section>
                )}

                <!-- Affiliated Doctors -->
                <section class="content-section">
                    <div class="section-header">
                        <h2>Affiliated Physicians</h2>
                        <span class="count">{doctors.length} doctors</span>
                    </div>

                    <div class="doctors-grid">
                        {doctors.length > 0 ? (
                            doctors.map((doctor) => (
                                <a href={`/doctors/${doctor.slug}`} class="doctor-card">
                                    <div class="doctor-avatar">
                                        {doctor.portrait_url && !doctor.portrait_url.startsWith('data:') ? (
                                            <img src={doctor.portrait_url} alt={doctor.full_name || ''} loading="lazy" />
                                        ) : (
                                            <div class="avatar-placeholder" style={`--tier-color: ${tierColors[doctor.tier || 'UNRANKED']}`}>
                                                {(doctor.full_name || '?').charAt(0)}
                                            </div>
                                        )}
                                    </div>
                                    <div class="doctor-info">
                                        <h4 class="doctor-name">
                                            {doctor.full_name}
                                            {doctor.isPrimary && <span class="primary-badge">Primary</span>}
                                        </h4>
                                        <p class="doctor-specialty">{doctor.specialty}</p>
                                        {doctor.role && <p class="doctor-role">{doctor.role}</p>}
                                    </div>
                                    <div class="doctor-stats">
                                        <span class={`tier-badge tier-${(doctor.tier || 'unranked').toLowerCase()}`}>
                                            {doctor.tier}
                                        </span>
                                        <span class="h-index">H: {doctor.h_index}</span>
                                    </div>
                                </a>
                            ))
                        ) : (
                            <p class="empty-message">No affiliated doctors found.</p>
                        )}
                    </div>
                </section>
            </main>

            <!-- Sidebar -->
            <aside class="sidebar">
                <!-- Quick Facts -->
                <div class="sidebar-card">
                    <h3>Quick Facts</h3>
                    <dl class="facts-list">
                        <div class="fact-row">
                            <dt>Type</dt>
                            <dd>{sectorLabels[institution.sector]}</dd>
                        </div>
                        {institution.geography?.country && (
                            <div class="fact-row">
                                <dt>Country</dt>
                                <dd>{institution.geography.country}</dd>
                            </div>
                        )}
                        {institution.geography?.city && (
                            <div class="fact-row">
                                <dt>City</dt>
                                <dd>{institution.geography.city}</dd>
                            </div>
                        )}
                        {institution.website && (
                            <div class="fact-row">
                                <dt>Website</dt>
                                <dd>
                                    <a href={institution.website} target="_blank" rel="noopener">
                                        Visit &rarr;
                                    </a>
                                </dd>
                            </div>
                        )}
                    </dl>
                </div>

                <!-- Specialties -->
                {specialties.length > 0 && (
                    <div class="sidebar-card">
                        <h3>Specialties</h3>
                        <div class="specialties-list">
                            {specialties.slice(0, 10).map(spec => (
                                <a href={`/doctors?specialty=${encodeURIComponent(spec || '')}`} class="specialty-tag">
                                    {spec}
                                </a>
                            ))}
                            {specialties.length > 10 && (
                                <span class="more-specialties">+{specialties.length - 10} more</span>
                            )}
                        </div>
                    </div>
                )}

                <!-- Back Link -->
                <a href="/institutions" class="back-link">
                    &larr; All Institutions
                </a>
            </aside>
        </div>
    </div>
</Layout>

<style>
    .institution-profile {
        padding: 40px 20px;
        max-width: var(--max);
    }

    /* Hero */
    .inst-hero {
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        padding: 40px;
        margin-bottom: 32px;
    }

    .hero-content {
        display: flex;
        gap: 32px;
        align-items: flex-start;
    }

    .hero-logo img,
    .logo-placeholder {
        width: 100px;
        height: 100px;
        border-radius: var(--r-4);
        object-fit: contain;
    }

    .hero-logo img {
        background: var(--paper);
        padding: 8px;
    }

    .logo-placeholder {
        background: var(--ink-blue);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: 500;
        color: var(--paper);
    }

    .hero-text h1 {
        font-family: var(--font-serif);
        font-size: 2.2rem;
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 8px;
    }

    .location {
        color: var(--ink-2);
        font-size: 1.1rem;
        margin: 0 0 16px;
    }

    .hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .sector-badge, .ranking-badge, .coe-badge {
        padding: 6px 14px;
        border-radius: var(--r-pill);
        font-size: 0.8rem;
        font-weight: 600;
    }

    .sector-public {
        background: var(--verdant-2);
        color: var(--verdant);
    }

    .sector-private {
        background: var(--ink-blue-2);
        color: var(--ink-blue);
    }

    .ranking-badge {
        background: var(--aged-gold-2);
        color: var(--titan-text);
    }

    .coe-badge {
        background: var(--ink-blue-2);
        color: var(--ink-blue);
    }

    /* Stats Bar */
    .stats-bar {
        display: flex;
        gap: 16px;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .stats-bar .stat-item {
        flex: 1;
        min-width: 120px;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        padding: 20px;
        text-align: center;
    }

    .stats-bar .stat-value {
        display: block;
        font-size: 1.8rem;
        font-weight: 500;
        color: var(--stat-color, var(--ink));
    }

    .stats-bar .stat-label {
        font-size: 0.75rem;
        color: var(--ink-3);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* Content Grid */
    .content-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 40px;
        align-items: start;
    }

    .content-section {
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        padding: 24px;
        margin-bottom: 24px;
    }

    .content-section h2 {
        font-family: var(--font-serif);
        font-size: 1.3rem;
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 16px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--rule);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--rule);
    }

    .section-header h2 {
        margin: 0;
        border: none;
        padding: 0;
    }

    .count {
        color: var(--ink-3);
        font-size: 0.9rem;
    }

    /* Doctors Grid */
    .doctors-grid {
        display: grid;
        gap: 12px;
    }

    .doctor-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
        text-decoration: none;
        color: inherit;
        transition: all 0.2s;
    }

    .doctor-card:hover {
        background: var(--paper-2);
        border-color: var(--rule-strong);
    }

    .doctor-avatar img,
    .avatar-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
    }

    .avatar-placeholder {
        background: var(--paper-3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 500;
        color: var(--ink-2);
    }

    .doctor-info {
        flex: 1;
    }

    .doctor-name {
        font-size: 0.95rem;
        font-weight: 500;
        margin: 0 0 2px;
        color: var(--ink);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .primary-badge {
        font-size: 0.65rem;
        padding: 2px 6px;
        background: var(--verdant-2);
        color: var(--verdant);
        border-radius: var(--r-2);
    }

    .doctor-specialty {
        font-size: 0.8rem;
        color: var(--ink-2);
        margin: 0;
    }

    .doctor-role {
        font-size: 0.75rem;
        color: var(--ink-3);
        margin: 2px 0 0;
    }

    .doctor-stats {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 4px;
    }

    .tier-badge {
        padding: 3px 10px;
        border-radius: var(--r-2);
        font-size: 0.7rem;
        font-weight: 500;
    }

    .tier-titan { background: var(--titan-bg); color: var(--titan-text); }
    .tier-elite { background: var(--elite-bg); color: var(--elite-text); }
    .tier-master { background: var(--master-bg); color: var(--master-text); }
    .tier-unranked { background: var(--paper-3); color: var(--ink-3); }

    .h-index {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--ink-3);
    }

    /* Sidebar */
    .sidebar-card {
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        padding: 20px;
        margin-bottom: 20px;
    }

    .sidebar-card h3 {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ink-3);
        margin: 0 0 16px;
    }

    .facts-list {
        margin: 0;
    }

    .fact-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid var(--rule);
    }

    .fact-row:last-child {
        border-bottom: none;
    }

    .fact-row dt {
        color: var(--ink-3);
        font-size: 0.85rem;
    }

    .fact-row dd {
        margin: 0;
        font-size: 0.85rem;
    }

    .fact-row a {
        color: var(--ink-blue);
        text-decoration: none;
    }

    .specialties-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .specialty-tag {
        padding: 4px 12px;
        background: var(--ink-blue-2);
        color: var(--ink-blue);
        border-radius: var(--r-pill);
        font-size: 0.75rem;
        text-decoration: none;
        transition: all 0.2s;
    }

    .specialty-tag:hover {
        background: var(--paper-3);
    }

    .more-specialties {
        color: var(--ink-3);
        font-size: 0.75rem;
        padding: 4px;
    }

    .back-link {
        display: block;
        color: var(--ink-blue);
        text-decoration: none;
        font-weight: 600;
    }

    .empty-message {
        color: var(--ink-3);
        text-align: center;
        padding: 40px;
    }

    @media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .sidebar {
            order: -1;
        }
    }

    @media (max-width: 768px) {
        .hero-content {
            flex-direction: column;
            text-align: center;
        }

        .hero-badges {
            justify-content: center;
        }
    }
</style>
