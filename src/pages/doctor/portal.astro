---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { getSession } from "../../lib/auth";
import { prisma } from "../../lib/prisma";

// Read session from cookie
const session = await getSession(Astro.request);

if (!session) {
    return Astro.redirect('/login?error=not_authenticated');
}

// Fetch real profile data
const profile = await prisma.profile.findUnique({
    where: { id: session.profileId },
    select: {
        id: true,
        slug: true,
        full_name: true,
        tier: true,
        specialty: true,
        h_index: true,
        ranking_score: true,
        claim_status: true,
    },
});

if (!profile) {
    return Astro.redirect('/login?error=profile_not_found');
}

const doctorName = profile.full_name;
const tier = profile.tier || 'STANDARD';
const slug = profile.slug;

// Fetch real view count
let viewCount = 0;
try {
    viewCount = await prisma.profileView.count({ where: { profile_id: profile.id } });
} catch { /* table may not exist yet */ }

// Fetch search appearance count (searches that led to clicking this profile)
let searchCount = 0;
try {
    searchCount = await prisma.searchLog.count({ where: { clickedSlug: profile.slug } });
} catch { /* optional */ }

const score = profile.ranking_score ? Number(profile.ranking_score).toFixed(1) : '—';
---

<Layout title="Doctor Portal — MDRPedia">
    <div class="min-h-screen pt-24 pb-20 container">
        <header
            class="flex justify-between items-center mb-12 border-b border-white/10 pb-8"
        >
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">
                    My Governance Dashboard
                </h1>
                <p class="text-gray-400">
                    Welcome back, <span class="text-white">{doctorName}</span>
                </p>
            </div>
            <div class="flex items-center gap-4">
                <div
                    class="px-3 py-1 bg-green-500/10 border border-green-500/20 rounded-full text-green-400 text-xs font-bold uppercase tracking-wider flex items-center gap-2"
                >
                    <span
                        class="w-2 h-2 rounded-full bg-green-500 animate-pulse"
                    ></span>
                    Verified Identity
                </div>
                {
                    tier === "TITAN" && (
                        <div class="px-3 py-1 bg-yellow-500/10 border border-yellow-500/20 rounded-full text-yellow-400 text-xs font-bold uppercase tracking-wider">
                            Titan Tier
                        </div>
                    )
                }
                <a href="/api/auth/logout" class="portal-logout-btn">Sign Out</a>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <!-- Sidebar -->
            <div class="space-y-2">
                <a
                    href="/doctor/portal"
                    class="block px-4 py-3 bg-white/10 text-white rounded-lg font-medium"
                    >Overview</a
                >
                <a
                    href={`/doctors/${slug}`}
                    class="block px-4 py-3 text-gray-400 hover:bg-white/5 rounded-lg transition-colors"
                    >View Profile</a
                >
                <a
                    href="/suggest-edit"
                    class="block px-4 py-3 text-gray-400 hover:bg-white/5 rounded-lg transition-colors"
                    >Suggest Edit</a
                >
                <a
                    href="#"
                    class="block px-4 py-3 text-gray-400 hover:bg-white/5 rounded-lg transition-colors"
                    >Analytics</a
                >
                <a
                    href="#"
                    class="block px-4 py-3 text-gray-400 hover:bg-white/5 rounded-lg transition-colors"
                    >Settings</a
                >
            </div>

            <!-- Main Content -->
            <div class="md:col-span-3 space-y-8">
                <!-- Analytics Cards -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div
                        class="p-6 bg-[#1a052e] border border-purple-500/30 rounded-2xl"
                    >
                        <div
                            class="text-purple-400 text-sm font-bold uppercase tracking-wider mb-2"
                        >
                            Profile Views
                        </div>
                        <div class="text-4xl font-bold text-white">{viewCount.toLocaleString()}</div>
                    </div>
                    <div
                        class="p-6 bg-white/5 border border-white/10 rounded-2xl"
                    >
                        <div
                            class="text-gray-400 text-sm font-bold uppercase tracking-wider mb-2"
                        >
                            Search Appearances
                        </div>
                        <div class="text-4xl font-bold text-white">{searchCount.toLocaleString()}</div>
                    </div>
                    <div
                        class="p-6 bg-white/5 border border-white/10 rounded-2xl"
                    >
                        <div
                            class="text-gray-400 text-sm font-bold uppercase tracking-wider mb-2"
                        >
                            MDR Score
                        </div>
                        <div class="text-4xl font-bold text-white">{score}</div>
                        {profile.h_index && (
                            <div class="text-xs text-gray-500 mt-2">
                                h-index: {profile.h_index}
                            </div>
                        )}
                    </div>
                </div>

                <!-- Content Lock Section -->
                <div class="p-8 bg-white/5 border border-white/10 rounded-2xl">
                    <div class="flex justify-between items-start mb-6">
                        <div>
                            <h2 class="text-xl font-bold text-white mb-2">
                                Content Lock
                            </h2>
                            <p class="text-gray-400 text-sm max-w-lg">
                                When enabled, your Biography, Education, and
                                Awards sections cannot be edited by the
                                community or AI scrapers. Only you can make
                                changes.
                            </p>
                        </div>
                        <div
                            class="relative inline-flex items-center cursor-pointer"
                        >
                            <input
                                type="checkbox"
                                checked
                                class="sr-only peer"
                            />
                            <div
                                class="w-14 h-7 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-green-500"
                            >
                            </div>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <div
                            class="px-4 py-2 bg-green-500/20 border border-green-500/30 rounded text-green-400 text-xs font-mono"
                        >
                            STATUS: ACTIVE
                        </div>
                    </div>
                </div>

                <!-- Recent Alerts -->
                <div class="space-y-4">
                    <h3 class="text-lg font-bold text-white">Recent Alerts</h3>
                    <div
                        class="p-4 bg-white/5 border border-white/10 rounded-xl flex items-center gap-4"
                    >
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <p class="text-sm text-white">
                            No new alerts. Your profile is up to date.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    /* ─── Portal Page — Editorial Design System Overrides ─────────────────── */

    /* ── Page wrapper ── */
    .min-h-screen {
        background: var(--paper);
        color: var(--ink);
    }

    /* ── Header ── */
    header.border-b {
        border-bottom-color: var(--rule) !important;
    }

    header h1 {
        color: var(--ink) !important;
        font-family: var(--font-serif);
        font-weight: 400 !important;
    }

    header p {
        color: var(--ink-3) !important;
    }

    header p span {
        color: var(--ink) !important;
    }

    /* ── Verified / Tier badges in header ── */
    .bg-green-500\/10 {
        background: var(--verdant-2) !important;
        border-color: var(--verdant) !important;
    }

    .text-green-400 {
        color: var(--verdant) !important;
    }

    .bg-green-500 {
        background: var(--verdant) !important;
    }

    .bg-yellow-500\/10 {
        background: var(--aged-gold-2) !important;
        border-color: var(--aged-gold) !important;
    }

    .border-yellow-500\/20 {
        border-color: var(--aged-gold) !important;
    }

    .text-yellow-400 {
        color: var(--titan-text) !important;
    }

    /* ── Logout button ── */
    .portal-logout-btn {
        font-size: 0.8rem;
        padding: 0.4rem 0.75rem;
        border: 1px solid var(--rule);
        border-radius: var(--r-pill);
        color: var(--ink-3);
        text-decoration: none;
        transition: all var(--t-fast) var(--ease);
    }

    .portal-logout-btn:hover {
        color: var(--sanguine);
        border-color: var(--sanguine);
    }

    /* ── Sidebar links ── */
    .bg-white\/10 {
        background: var(--paper-3) !important;
    }

    .text-white {
        color: var(--ink) !important;
    }

    .text-gray-400 {
        color: var(--ink-3) !important;
    }

    .text-gray-500 {
        color: var(--ink-3) !important;
    }

    a.hover\:bg-white\/5:hover {
        background: var(--paper-2) !important;
    }

    /* ── Analytics Cards ── */
    .bg-\[\#1a052e\] {
        background: var(--ink-blue-2) !important;
        border-color: var(--ink-blue) !important;
    }

    .border-purple-500\/30 {
        border-color: var(--ink-blue) !important;
    }

    .text-purple-400 {
        color: var(--ink-blue) !important;
    }

    .bg-white\/5 {
        background: var(--paper-2) !important;
    }

    .border-white\/10 {
        border-color: var(--rule) !important;
    }

    .text-4xl.font-bold {
        color: var(--ink) !important;
        font-weight: 500 !important;
        font-family: var(--font-mono);
    }

    /* ── Content Lock section ── */
    h2.text-xl {
        color: var(--ink) !important;
        font-family: var(--font-serif);
        font-weight: 400 !important;
    }

    /* ── Toggle switch ── */
    .bg-gray-700 {
        background: var(--rule-strong) !important;
    }

    .peer-checked\:bg-green-500:is(:has(~ :checked), .peer:checked ~ &) {
        background: var(--verdant) !important;
    }

    /* ── Status badges ── */
    .bg-green-500\/20 {
        background: var(--verdant-2) !important;
    }

    .border-green-500\/30 {
        border-color: var(--verdant) !important;
    }

    .border-green-500\/20 {
        border-color: var(--verdant) !important;
    }

    /* ── Recent Alerts ── */
    h3.text-lg {
        color: var(--ink) !important;
        font-family: var(--font-serif);
        font-weight: 400 !important;
    }

    .bg-blue-500 {
        background: var(--ink-blue) !important;
    }

    .text-sm.text-white {
        color: var(--ink) !important;
    }

    /* ── Card border-radius normalization ── */
    .rounded-2xl {
        border-radius: var(--r-4) !important;
    }

    .rounded-xl {
        border-radius: var(--r-4) !important;
    }

    .rounded-lg {
        border-radius: var(--r-3) !important;
    }

    .rounded-full {
        border-radius: var(--r-pill) !important;
    }

    /* ── Font-weight normalization ── */
    .font-bold {
        font-weight: 500 !important;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        header.flex {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }

        .md\:grid-cols-4 {
            grid-template-columns: 1fr !important;
        }

        .md\:grid-cols-3 {
            grid-template-columns: 1fr !important;
        }

        .md\:col-span-3 {
            grid-column: span 1 !important;
        }
    }

    @media (max-width: 480px) {
        header h1 {
            font-size: 1.5rem !important;
        }

        .text-4xl {
            font-size: 2rem !important;
        }

        .flex.gap-4 {
            flex-wrap: wrap;
        }
    }
</style>
