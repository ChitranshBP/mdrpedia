---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Page Not Found | MDRPedia">
    <div class="error-page">
        <div class="error-content">
            <!-- Animated 404 -->
            <div class="error-code">
                <span class="digit">4</span>
                <span class="digit pulse">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        <path d="M12 8v4M12 16h.01" />
                    </svg>
                </span>
                <span class="digit">4</span>
            </div>

            <h1 class="error-title">Page Not Found</h1>
            <p class="error-description">
                The profile or page you're looking for might have been moved,
                renamed, or is pending verification in our database.
            </p>

            <!-- Quick Actions -->
            <div class="error-actions">
                <a href="/" class="btn-primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                        <polyline points="9,22 9,12 15,12 15,22" />
                    </svg>
                    Return Home
                </a>
                <a href="/doctors" class="btn-secondary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                    </svg>
                    Browse Doctors
                </a>
            </div>

            <!-- Search Box -->
            <div class="search-card">
                <div class="search-header">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.3-4.3" />
                    </svg>
                    <span>Looking for a specific doctor?</span>
                </div>
                <form action="/doctors" method="get" class="search-form">
                    <input
                        type="text"
                        name="q"
                        placeholder="Search by name, specialty, or institution..."
                        class="search-input"
                        autocomplete="off"
                    />
                    <button type="submit" class="search-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </button>
                </form>
            </div>

            <!-- Popular Links -->
            <div class="popular-links">
                <span class="links-label">Popular destinations:</span>
                <div class="links-grid">
                    <a href="/rankings" class="quick-link">
                        <span class="link-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6m12 5h1.5a2.5 2.5 0 0 0 0-5H18M6 9a6 6 0 0 0 12 0V4H6v5zm3 12h6m-3-3v3"/></svg></span>
                        Rankings
                    </a>
                    <a href="/rare-diseases" class="quick-link">
                        <span class="link-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 15c6.667-6 13.333 0 20-6M2 9c6.667 6 13.333 0 20 6M9 3v18m6-18v18"/></svg></span>
                        Rare Diseases
                    </a>
                    <a href="/hospitals" class="quick-link">
                        <span class="link-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4M12 6v4M10 8h4"/></svg></span>
                        Hospitals
                    </a>
                    <a href="/doctor/claim" class="quick-link">
                        <span class="link-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 12 15 16 10"/></svg></span>
                        Claim Profile
                    </a>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .error-page {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--s-9) var(--gutter);
    }

    .error-content {
        max-width: 540px;
        text-align: center;
    }

    /* 404 Code */
    .error-code {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--s-2);
        margin-bottom: var(--s-5);
    }

    .digit {
        font-family: var(--font-serif);
        font-size: 6rem;
        font-weight: 400;
        color: var(--ink);
        line-height: 1;
        animation: fadeIn 0.6s ease-out both;
    }

    .digit:nth-child(1) { animation-delay: 0.1s; }
    .digit:nth-child(3) { animation-delay: 0.3s; }

    .digit.pulse {
        width: 100px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--ink-blue-2);
        border: 2px solid var(--ink-blue);
        border-radius: var(--r-4);
        animation: fadeIn 0.6s ease-out 0.2s both;
    }

    .digit.pulse svg {
        width: 48px;
        height: 48px;
        color: var(--ink-blue);
    }

    .error-title {
        font-family: var(--font-serif);
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 var(--s-3);
        animation: fadeIn 0.6s ease-out 0.3s both;
    }

    .error-description {
        font-size: 1.1rem;
        color: var(--ink-2);
        line-height: 1.7;
        margin: 0 0 var(--s-6);
        animation: fadeIn 0.6s ease-out 0.4s both;
    }

    /* Actions */
    .error-actions {
        display: flex;
        gap: var(--s-3);
        justify-content: center;
        margin-bottom: var(--s-7);
        animation: fadeIn 0.6s ease-out 0.5s both;
    }

    .btn-primary,
    .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: var(--s-2);
        padding: 12px 20px;
        border-radius: var(--r-2);
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 14px;
        text-decoration: none;
        transition: all var(--t-fast) var(--ease);
    }

    .btn-primary {
        background: var(--ink);
        color: var(--paper);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-2);
    }

    .btn-secondary {
        background: transparent;
        border: 1px solid var(--ink);
        color: var(--ink);
    }

    .btn-secondary:hover {
        background: var(--ink);
        color: var(--paper);
        transform: translateY(-2px);
    }

    .btn-primary svg,
    .btn-secondary svg {
        width: 18px;
        height: 18px;
    }

    /* Search Card */
    .search-card {
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
        padding: var(--s-5);
        margin-bottom: var(--s-6);
        animation: fadeIn 0.6s ease-out 0.6s both;
    }

    .search-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: var(--s-4);
        color: var(--ink);
        font-weight: 500;
    }

    .search-header svg {
        width: 18px;
        height: 18px;
        color: var(--ink-blue);
    }

    .search-form {
        display: flex;
        gap: var(--s-2);
    }

    .search-input {
        flex: 1;
        padding: 12px 16px;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-2);
        color: var(--ink);
        font-family: var(--font-serif);
        font-size: 0.95rem;
        outline: none;
        transition: border-color var(--t-fast) var(--ease);
    }

    .search-input::placeholder { color: var(--ink-3); }

    .search-input:focus {
        border-color: var(--ink);
        box-shadow: 0 0 0 3px color-mix(in oklch, var(--ink-blue) 12%, transparent);
    }

    .search-btn {
        padding: 12px 16px;
        background: var(--ink);
        border: none;
        border-radius: var(--r-2);
        color: var(--paper);
        cursor: pointer;
        transition: all var(--t-fast) var(--ease);
    }

    .search-btn:hover { transform: scale(1.05); }
    .search-btn svg { width: 18px; height: 18px; }

    /* Popular Links */
    .popular-links { animation: fadeIn 0.6s ease-out 0.7s both; }

    .links-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--ink-3);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin-bottom: var(--s-4);
    }

    .links-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--s-3);
    }

    .quick-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--s-2);
        padding: var(--s-4) var(--s-3);
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
        color: var(--ink-2);
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all var(--t-fast) var(--ease);
    }

    .quick-link:hover {
        border-color: var(--rule-strong);
        color: var(--ink);
        transform: translateY(-2px);
        box-shadow: var(--shadow-2);
    }

    .link-icon {
        font-size: 1.4rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @media (max-width: 768px) {
        .digit { font-size: 4rem; }
        .digit.pulse { width: 70px; height: 70px; }
        .digit.pulse svg { width: 32px; height: 32px; }
        .error-actions { flex-direction: column; }
        .links-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>
