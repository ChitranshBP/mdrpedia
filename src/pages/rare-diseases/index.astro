---
export const prerender = true;
/**
 * MDRPedia — Rare Diseases Directory
 * Comprehensive database of rare diseases with expert connections
 */
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const rareDiseases = await getCollection("rareDiseases");
const doctors = await getCollection("doctors");

// Sort diseases alphabetically
const sortedDiseases = rareDiseases.sort((a, b) =>
    a.data.name.localeCompare(b.data.name)
);

// Get unique categories
const categories = [...new Set(sortedDiseases.map(d => d.data.category))].sort();

// Category SVG icon paths (24x24 viewBox, stroke-based)
const CATEGORY_ICONS: Record<string, string> = {
    'GENETIC': 'M2 15c6.667-6 13.333 0 20-6M2 9c6.667 6 13.333 0 20 6M9 3v18m6-18v18',
    'METABOLIC': 'M9 3h6v2H9V3zm0 4v6l-3 6h12l-3-6V7H9z',
    'NEUROLOGICAL': 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
    'CARDIOVASCULAR': 'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z',
    'IMMUNOLOGICAL': 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    'ONCOLOGICAL': 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    'HEMATOLOGICAL': 'M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z',
    'MUSCULOSKELETAL': 'M22 12h-4l-3 9L9 3l-3 9H2',
    'DERMATOLOGICAL': 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    'GASTROINTESTINAL': 'M22 12h-4l-3 9L9 3l-3 9H2',
    'RESPIRATORY': 'M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2',
    'ENDOCRINE': 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
    'OPHTHALMOLOGICAL': 'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8zM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6z',
    'OTHER': 'M9 3h6v2H9V3zm0 4v6l-3 6h12l-3-6V7H9z',
};

// Category info
const CATEGORY_INFO: Record<string, { icon: string; color: string; label: string }> = {
    'GENETIC': { icon: CATEGORY_ICONS['GENETIC'], color: '#a78bfa', label: 'Genetic' },
    'METABOLIC': { icon: CATEGORY_ICONS['METABOLIC'], color: '#fbbf24', label: 'Metabolic' },
    'NEUROLOGICAL': { icon: CATEGORY_ICONS['NEUROLOGICAL'], color: '#f472b6', label: 'Neurological' },
    'CARDIOVASCULAR': { icon: CATEGORY_ICONS['CARDIOVASCULAR'], color: '#ef4444', label: 'Cardiovascular' },
    'IMMUNOLOGICAL': { icon: CATEGORY_ICONS['IMMUNOLOGICAL'], color: '#10b981', label: 'Immunological' },
    'ONCOLOGICAL': { icon: CATEGORY_ICONS['ONCOLOGICAL'], color: '#8b5cf6', label: 'Oncological' },
    'HEMATOLOGICAL': { icon: CATEGORY_ICONS['HEMATOLOGICAL'], color: '#dc2626', label: 'Hematological' },
    'MUSCULOSKELETAL': { icon: CATEGORY_ICONS['MUSCULOSKELETAL'], color: '#78716c', label: 'Musculoskeletal' },
    'DERMATOLOGICAL': { icon: CATEGORY_ICONS['DERMATOLOGICAL'], color: '#f97316', label: 'Dermatological' },
    'GASTROINTESTINAL': { icon: CATEGORY_ICONS['GASTROINTESTINAL'], color: '#84cc16', label: 'Gastrointestinal' },
    'RESPIRATORY': { icon: CATEGORY_ICONS['RESPIRATORY'], color: '#38bdf8', label: 'Respiratory' },
    'ENDOCRINE': { icon: CATEGORY_ICONS['ENDOCRINE'], color: '#c084fc', label: 'Endocrine' },
    'OPHTHALMOLOGICAL': { icon: CATEGORY_ICONS['OPHTHALMOLOGICAL'], color: '#06b6d4', label: 'Ophthalmological' },
    'OTHER': { icon: CATEGORY_ICONS['OTHER'], color: '#71717a', label: 'Other' }
};

// Count doctors treating each disease
function getDoctorCount(disease: any) {
    return doctors.filter(doc => {
        const rareConditions = doc.data.rareConditions || [];
        const conditionsTreated = doc.data.conditionsTreated || [];
        const allConditions = [...rareConditions, ...conditionsTreated].map(c => c.toLowerCase());
        return allConditions.some(c =>
            c.includes(disease.data.name.toLowerCase()) ||
            disease.data.aliases?.some((a: string) => c.includes(a.toLowerCase()))
        );
    }).length;
}

// Stats
const totalDiseases = sortedDiseases.length;
const totalTrials = sortedDiseases.reduce((sum, d) => sum + (d.data.clinicalTrialsCount || 0), 0);
---

<Layout
    title="Rare Diseases Directory — MDRPedia"
    description="Comprehensive database of rare diseases with expert physicians, treatment options, research updates, and patient resources."
>
    <div class="rare-diseases-page">
        <!-- Hero Section -->
        <header class="page-hero">
            <div class="container">
                <div class="hero-content">
                    <span class="hero-badge">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 6v6l4 2"/>
                        </svg>
                        RARE DISEASES DIRECTORY
                    </span>
                    <h1>Understanding Rare Diseases</h1>
                    <p class="hero-description">
                        Explore our comprehensive database of rare diseases, connect with leading specialists,
                        and discover the latest treatments and ongoing research.
                    </p>

                    <!-- Stats -->
                    <div class="hero-stats">
                        <div class="stat">
                            <span class="stat__value">{totalDiseases}</span>
                            <span class="stat__label">Diseases</span>
                        </div>
                        <div class="stat">
                            <span class="stat__value">{categories.length}</span>
                            <span class="stat__label">Categories</span>
                        </div>
                        <div class="stat">
                            <span class="stat__value">{totalTrials}+</span>
                            <span class="stat__label">Active Trials</span>
                        </div>
                    </div>

                    <!-- Search -->
                    <div class="hero-search">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="M21 21l-4.35-4.35"/>
                        </svg>
                        <input
                            type="text"
                            id="disease-search"
                            placeholder="Search diseases by name, symptoms, or category..."
                            autocomplete="off"
                        />
                    </div>
                </div>
            </div>
        </header>

        <!-- Category Filter -->
        <section class="filter-section">
            <div class="container">
                <div class="category-pills">
                    <button class="category-pill active" data-category="all">
                        All Diseases
                    </button>
                    {categories.map(cat => {
                        const info = CATEGORY_INFO[cat] || CATEGORY_INFO['OTHER'];
                        const count = sortedDiseases.filter(d => d.data.category === cat).length;
                        return (
                            <button
                                class="category-pill"
                                data-category={cat}
                                style={`--cat-color: ${info.color}`}
                            >
                                <span class="pill-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={info.icon}/></svg></span>
                                {info.label}
                                <span class="pill-count">{count}</span>
                            </button>
                        );
                    })}
                </div>
            </div>
        </section>

        <!-- Diseases Grid -->
        <main class="diseases-section">
            <div class="container">
                <div class="diseases-grid" id="diseases-grid">
                    {sortedDiseases.map((disease) => {
                        const catInfo = CATEGORY_INFO[disease.data.category] || CATEGORY_INFO['OTHER'];
                        const doctorCount = getDoctorCount(disease);
                        return (
                            <a
                                href={`/rare-diseases/${disease.data.slug}`}
                                class="disease-card"
                                data-category={disease.data.category}
                                data-name={disease.data.name.toLowerCase()}
                                data-aliases={disease.data.aliases?.join(' ').toLowerCase() || ''}
                                data-symptoms={disease.data.symptoms?.join(' ').toLowerCase() || ''}
                            >
                                <div class="card-header">
                                    <span class="card-category" style={`--cat-color: ${catInfo.color}`}>
                                        <span class="cat-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={catInfo.icon}/></svg></span>
                                        {catInfo.label}
                                    </span>
                                    {disease.data.researchStatus === 'ACTIVE_TRIALS' && (
                                        <span class="research-badge">
                                            <span class="pulse"></span>
                                            Active Research
                                        </span>
                                    )}
                                </div>

                                <h3 class="card-title">{disease.data.name}</h3>

                                {disease.data.aliases && disease.data.aliases.length > 0 && (
                                    <p class="card-aliases">
                                        Also known as: {disease.data.aliases.slice(0, 2).join(', ')}
                                    </p>
                                )}

                                <p class="card-description">
                                    {disease.data.description.slice(0, 150)}...
                                </p>

                                <div class="card-meta">
                                    {disease.data.prevalence && (
                                        <span class="meta-item">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                                <circle cx="9" cy="7" r="4"/>
                                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                                                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                            </svg>
                                            {disease.data.prevalence}
                                        </span>
                                    )}
                                    {disease.data.clinicalTrialsCount > 0 && (
                                        <span class="meta-item trials">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                                                <polyline points="14 2 14 8 20 8"/>
                                            </svg>
                                            {disease.data.clinicalTrialsCount} trials
                                        </span>
                                    )}
                                </div>

                                <div class="card-footer">
                                    <div class="specialists">
                                        {doctorCount > 0 ? (
                                            <span class="specialists-count">
                                                {doctorCount} specialist{doctorCount !== 1 ? 's' : ''}
                                            </span>
                                        ) : (
                                            <span class="specialists-types">
                                                {disease.data.specialistTypes?.slice(0, 2).join(', ')}
                                            </span>
                                        )}
                                    </div>
                                    <span class="card-arrow">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M5 12h14M12 5l7 7-7 7"/>
                                        </svg>
                                    </span>
                                </div>
                            </a>
                        );
                    })}
                </div>

                <!-- Empty State -->
                <div class="empty-state" id="empty-state" hidden>
                    <span class="empty-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16zM21 21l-4.35-4.35"/></svg></span>
                    <h3>No diseases found</h3>
                    <p>Try adjusting your search or filter criteria</p>
                </div>
            </div>
        </main>

        <!-- Resources Section -->
        <section class="resources-section">
            <div class="container">
                <h2 class="section-title">Patient Resources</h2>
                <p class="section-subtitle">Trusted organizations and databases for rare disease information</p>
                <div class="resources-grid">
                    <a href="https://rarediseases.org" target="_blank" rel="noopener" class="resource-card">
                        <span class="resource-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M4 21V8M20 21V8"/></svg></span>
                        <h4>NORD</h4>
                        <p>National Organization for Rare Disorders</p>
                    </a>
                    <a href="https://www.orpha.net" target="_blank" rel="noopener" class="resource-card">
                        <span class="resource-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
                        <h4>Orphanet</h4>
                        <p>European rare disease database</p>
                    </a>
                    <a href="https://clinicaltrials.gov" target="_blank" rel="noopener" class="resource-card">
                        <span class="resource-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6v2H9V3zm0 4v6l-3 6h12l-3-6V7H9z"/></svg></span>
                        <h4>ClinicalTrials.gov</h4>
                        <p>Find active clinical trials</p>
                    </a>
                    <a href="https://www.omim.org" target="_blank" rel="noopener" class="resource-card">
                        <span class="resource-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 15c6.667-6 13.333 0 20-6M2 9c6.667 6 13.333 0 20 6M9 3v18m6-18v18"/></svg></span>
                        <h4>OMIM</h4>
                        <p>Genetic disorder database</p>
                    </a>
                </div>
            </div>
        </section>
    </div>
</Layout>

<script>
    const searchInput = document.getElementById('disease-search') as HTMLInputElement;
    const categoryPills = document.querySelectorAll<HTMLButtonElement>('.category-pill');
    const diseaseCards = document.querySelectorAll<HTMLElement>('.disease-card');
    const emptyState = document.getElementById('empty-state');

    let currentCategory = 'all';
    let searchQuery = '';

    function filterDiseases() {
        let visibleCount = 0;

        diseaseCards.forEach(card => {
            const category = card.dataset.category;
            const name = card.dataset.name || '';
            const aliases = card.dataset.aliases || '';
            const symptoms = card.dataset.symptoms || '';

            const matchesCategory = currentCategory === 'all' || category === currentCategory;
            const matchesSearch = !searchQuery ||
                name.includes(searchQuery) ||
                aliases.includes(searchQuery) ||
                symptoms.includes(searchQuery);

            if (matchesCategory && matchesSearch) {
                card.style.display = '';
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        if (emptyState) {
            emptyState.hidden = visibleCount > 0;
        }
    }

    // Category filter
    categoryPills.forEach(pill => {
        pill.addEventListener('click', () => {
            categoryPills.forEach(p => p.classList.remove('active'));
            pill.classList.add('active');
            currentCategory = pill.dataset.category || 'all';
            filterDiseases();
        });
    });

    // Search
    searchInput?.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
        filterDiseases();
    });
</script>

<style>
    .rare-diseases-page {
        background: var(--paper);
        min-height: 100vh;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* Hero */
    .page-hero {
        padding: 5rem 0 3rem;
        background: var(--paper);
        border-bottom: 1px solid var(--rule);
        position: relative;
        overflow: hidden;
    }

    .hero-content {
        max-width: 720px;
        margin: 0 auto;
        text-align: center;
        position: relative;
        z-index: 1;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 18px;
        background: var(--ink-blue-2);
        border: 1px solid var(--ink-blue);
        border-radius: var(--r-pill);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        font-family: var(--font-mono);
        color: var(--ink-blue);
        margin-bottom: 1.5rem;
    }

    .page-hero h1 {
        font-family: var(--font-serif);
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 1rem;
        letter-spacing: -0.03em;
    }

    .hero-description {
        font-size: 1.15rem;
        color: var(--ink-2);
        line-height: 1.7;
        margin: 0 0 2.5rem;
    }

    .hero-stats {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-bottom: 2.5rem;
    }

    .stat {
        text-align: center;
        padding: 1rem 1.5rem;
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        transition: all var(--t-fast);
    }

    .stat:hover {
        background: var(--paper-3);
        transform: translateY(-2px);
    }

    .stat__value {
        display: block;
        font-family: var(--font-mono);
        font-size: 2.25rem;
        font-weight: 500;
        color: var(--ink-blue);
        line-height: 1.2;
    }

    .stat__label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink-3);
        font-weight: 600;
    }

    .hero-search {
        position: relative;
        max-width: 540px;
        margin: 0 auto;
    }

    .hero-search svg {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--ink-3);
        transition: color var(--t-fast);
    }

    .hero-search:focus-within svg {
        color: var(--ink-blue);
    }

    .hero-search input {
        width: 100%;
        height: 60px;
        padding: 0 24px 0 56px;
        background: var(--paper);
        border: 2px solid var(--rule);
        border-radius: var(--r-4);
        font-size: 1rem;
        color: var(--ink);
        outline: none;
        transition: all var(--t-base);
        box-shadow: var(--shadow-2);
    }

    .hero-search input::placeholder {
        color: var(--ink-3);
    }

    .hero-search input:focus {
        border-color: var(--ink-blue);
        box-shadow: var(--shadow-3);
    }

    /* Filter Section */
    .filter-section {
        padding: 1.5rem 0;
        background: var(--paper-2);
        border-bottom: 1px solid var(--rule);
        position: sticky;
        top: 0;
        z-index: 20;
    }

    .category-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
    }

    .category-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-pill);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--ink-2);
        cursor: pointer;
        transition: all var(--t-fast);
    }

    .category-pill:hover {
        background: var(--paper-3);
        border-color: var(--rule-strong);
        color: var(--ink);
    }

    .category-pill.active {
        background: var(--ink-blue);
        border-color: var(--ink-blue);
        color: var(--paper);
    }

    .pill-icon {
        font-size: 0.9rem;
    }

    .pill-count {
        padding: 2px 8px;
        background: var(--paper-3);
        border-radius: var(--r-pill);
        font-size: 0.7rem;
        font-weight: 600;
        font-family: var(--font-mono);
    }

    .category-pill.active .pill-count {
        background: var(--ink-blue-2);
        color: var(--paper);
    }

    /* Diseases Grid */
    .diseases-section {
        padding: 3rem 0 4rem;
    }

    .diseases-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1.25rem;
    }

    .disease-card {
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 1.75rem;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        text-decoration: none;
        color: inherit;
        transition: all var(--t-base);
        overflow: hidden;
    }

    .disease-card::before {
        display: none;
    }

    .disease-card:hover {
        border-color: var(--rule-strong);
        box-shadow: var(--shadow-3);
        transform: translateY(-4px);
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .card-category {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 5px 12px;
        background: var(--paper-2);
        border-radius: var(--r-3);
        font-size: 0.7rem;
        font-weight: 600;
        font-family: var(--font-mono);
        color: var(--cat-color, var(--ink-blue));
    }

    .cat-icon {
        font-size: 0.8rem;
    }

    .research-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        background: var(--verdant-2);
        border-radius: var(--r-pill);
        font-size: 0.65rem;
        font-weight: 600;
        color: var(--verdant);
    }

    .pulse {
        width: 6px;
        height: 6px;
        background: var(--verdant);
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.5); }
    }

    .card-title {
        font-family: var(--font-serif);
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--ink);
        margin: 0 0 0.5rem;
        line-height: 1.3;
        letter-spacing: -0.01em;
    }

    .card-aliases {
        font-size: 0.75rem;
        color: var(--ink-3);
        margin: 0 0 0.75rem;
        font-style: italic;
    }

    .card-description {
        font-size: 0.875rem;
        color: var(--ink-2);
        line-height: 1.6;
        margin: 0 0 1rem;
        flex: 1;
    }

    .card-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1rem;
        padding-top: 1rem;
