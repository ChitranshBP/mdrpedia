---
export const prerender = true;
/**
 * MDRPedia — Admin Login Page
 * Premium authentication experience
 */
import Layout from "../layouts/Layout.astro";
---

<Layout title="Admin Login — MDRPedia" description="Secure Admin Access">
    <div class="login-page">
        <!-- Background Elements -->
        <div class="login-bg">
            <div class="bg-gradient"></div>
            <div class="bg-grid"></div>
            <div class="bg-orb bg-orb--1"></div>
            <div class="bg-orb bg-orb--2"></div>
        </div>

        <div class="login-container">
            <!-- Logo Section -->
            <div class="login-logo">
                <a href="/" class="logo-link">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6"></path>
                    </svg>
                    <span>MDR<strong>Pedia</strong></span>
                </a>
            </div>

            <!-- Login Card -->
            <div class="login-card">
                <div class="login-card__header">
                    <div class="header-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <path d="M9 12l2 2 4-4"/>
                        </svg>
                    </div>
                    <h1>Admin Access</h1>
                    <p>Enter your credentials to access the admin dashboard</p>
                </div>

                <form id="loginForm" class="login-form">
                    <div class="form-group">
                        <label for="key">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.778 7.778 5.5 5.5 0 017.778-7.778zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
                            </svg>
                            Access Key
                        </label>
                        <div class="input-wrapper">
                            <input
                                type="password"
                                id="key"
                                name="key"
                                placeholder="Enter your access key"
                                autocomplete="current-password"
                                required
                            />
                            <button type="button" class="toggle-visibility" aria-label="Toggle password visibility">
                                <svg class="eye-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                                <svg class="eye-closed" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
                                    <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>
                                    <line x1="1" y1="1" x2="23" y2="23"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="login-btn">
                        <span>Access Dashboard</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </button>
                </form>

                <div class="login-footer">
                    <div class="security-badges">
                        <div class="badge">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0110 0v4"/>
                            </svg>
                            <span>256-bit SSL</span>
                        </div>
                        <div class="badge">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                            <span>Secure Access</span>
                        </div>
                    </div>
                    <p class="help-text">
                        Need help? Contact <a href="mailto:admin@mdrpedia.com">admin@mdrpedia.com</a>
                    </p>
                </div>
            </div>

            <!-- Doctor Portal Login -->
            <div class="login-card doctor-login-card">
                <div class="login-card__header">
                    <div class="header-icon" style="background: var(--verdant-2); border-color: var(--verdant); color: var(--verdant);">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </div>
                    <h1>Doctor Portal</h1>
                    <p>Sign in with your verified email to manage your profile</p>
                </div>

                <form id="doctorLoginForm" class="login-form">
                    <div class="form-group">
                        <label for="doctor-email">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                            Email Address
                        </label>
                        <div class="input-wrapper">
                            <input
                                type="email"
                                id="doctor-email"
                                name="email"
                                placeholder="Your verified email"
                                autocomplete="email"
                                required
                            />
                        </div>
                    </div>

                    <button type="submit" class="login-btn" style="background: var(--verdant);">
                        <span>Send Magic Link</span>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                    </button>

                    <p class="doctor-login-status" aria-live="polite" style="font-size: 13px; text-align: center; min-height: 20px; margin: 0;"></p>
                </form>
            </div>

            <!-- Back to Home -->
            <a href="/" class="back-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Back to MDRPedia
            </a>
        </div>
    </div>
</Layout>

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
        background: var(--paper);
    }

    /* Background — simplified, no glassmorphism */
    .login-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .bg-gradient {
        display: none;
    }

    .bg-grid {
        display: none;
    }

    .bg-orb {
        display: none;
    }

    .bg-orb--1 {
        display: none;
    }

    .bg-orb--2 {
        display: none;
    }

    /* Container */
    .login-container {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 440px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    /* Logo */
    .login-logo {
        text-align: center;
    }

    .logo-link {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: var(--ink);
        font-size: 1.5rem;
        font-weight: 500;
    }

    .logo-link svg {
        color: var(--ink-blue);
    }

    .logo-link strong {
        font-weight: 700;
    }

    /* Card */
    .login-card {
        width: 100%;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        padding: 2.5rem;
        box-shadow: var(--shadow-3);
    }

    .login-card__header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .header-icon {
        width: 64px;
        height: 64px;
        margin: 0 auto 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--ink-blue-2);
        border: 1px solid var(--ink-blue);
        border-radius: var(--r-4);
        color: var(--ink-blue);
    }

    .login-card__header h1 {
        font-size: 1.75rem;
        font-weight: 500;
        font-family: var(--font-serif);
        color: var(--ink);
        margin: 0 0 0.5rem;
    }

    .login-card__header p {
        font-size: 0.9rem;
        color: var(--ink-3);
        margin: 0;
    }

    /* Form */
    .login-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--ink-2);
    }

    .form-group label svg {
        color: var(--ink-3);
    }

    .input-wrapper {
        position: relative;
    }

    .input-wrapper input {
        width: 100%;
        padding: 1rem 3rem 1rem 1.25rem;
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
        font-size: 1rem;
        color: var(--ink);
        transition: border-color var(--t-fast) var(--ease);
    }

    .input-wrapper input::placeholder {
        color: var(--ink-3);
    }

    .input-wrapper input:focus {
        outline: none;
        border-color: var(--ink-blue);
        box-shadow: 0 0 0 3px color-mix(in oklch, var(--ink-blue) 12%, transparent);
    }

    .toggle-visibility {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        padding: 4px;
        color: var(--ink-3);
        cursor: pointer;
        transition: color var(--t-fast) var(--ease);
    }

    .toggle-visibility:hover {
        color: var(--ink-2);
    }

    .login-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        width: 100%;
        padding: 1rem 1.5rem;
        background: var(--ink);
        border: none;
        border-radius: var(--r-3);
        font-size: 1rem;
        font-weight: 500;
        color: var(--paper);
        cursor: pointer;
        transition: opacity var(--t-fast) var(--ease);
    }

    .login-btn:hover {
        opacity: 0.85;
    }

    .login-btn:active {
        opacity: 0.75;
    }

    /* Footer */
    .login-footer {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--rule);
    }

    .security-badges {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .badge {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.75rem;
        color: var(--ink-3);
    }

    .badge svg {
        color: var(--verdant);
    }

    .help-text {
        font-size: 0.8rem;
        color: var(--ink-3);
        text-align: center;
        margin: 0;
    }

    .help-text a {
        color: var(--ink-blue);
        text-decoration: none;
    }

    .help-text a:hover {
        text-decoration: underline;
    }

    /* Back Link */
    .back-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: var(--ink-3);
        text-decoration: none;
        transition: color var(--t-fast) var(--ease);
    }

    .back-link:hover {
        color: var(--ink-2);
    }

    /* Responsive */
    @media (max-width: 768px) {
        .login-page {
            padding: 1.5rem;
        }
    }

    @media (max-width: 480px) {
        .login-card {
            padding: 2rem 1.5rem;
        }

        .security-badges {
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }
    }
</style>

<script>
    // Password visibility toggle
    const toggleBtn = document.querySelector('.toggle-visibility');
    const passwordInput = document.getElementById('key') as HTMLInputElement;
    const eyeOpen = document.querySelector('.eye-open') as SVGElement;
    const eyeClosed = document.querySelector('.eye-closed') as SVGElement;

    toggleBtn?.addEventListener('click', () => {
        if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            eyeOpen.style.display = 'none';
            eyeClosed.style.display = 'block';
        } else {
            passwordInput.type = 'password';
            eyeOpen.style.display = 'block';
            eyeClosed.style.display = 'none';
        }
    });

    // Admin form submission
    const form = document.getElementById("loginForm");
    form?.addEventListener("submit", (e) => {
        e.preventDefault();
        const input = document.getElementById("key") as HTMLInputElement;
        if (input && input.value) {
            window.location.href = `/admin?key=${encodeURIComponent(input.value)}`;
        }
    });

    // Doctor portal magic link form
    const doctorForm = document.getElementById("doctorLoginForm");
    const statusEl = document.querySelector('.doctor-login-status') as HTMLElement;

    doctorForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const emailInput = document.getElementById("doctor-email") as HTMLInputElement;
        const submitBtn = doctorForm.querySelector('.login-btn') as HTMLButtonElement;
        const email = emailInput?.value?.trim();

        if (!email) return;

        // Disable form while submitting
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.6';
        statusEl.textContent = 'Sending magic link...';
        statusEl.style.color = 'var(--ink-3)';

        try {
            const res = await fetch('/api/auth/magic-link', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email }),
            });

            const data = await res.json();

            if (res.ok) {
                statusEl.textContent = 'Check your email for a magic link to sign in.';
                statusEl.style.color = 'var(--verdant)';
                emailInput.value = '';
            } else {
                statusEl.textContent = data.error || 'Something went wrong. Please try again.';
                statusEl.style.color = 'var(--sanguine)';
            }
        } catch {
            statusEl.textContent = 'Network error. Please try again.';
            statusEl.style.color = 'var(--sanguine)';
        } finally {
            submitBtn.disabled = false;
            submitBtn.style.opacity = '1';
        }
    });
</script>
