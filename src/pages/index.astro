}
.regional__card:hover { border-color: var(--ink); background: var(--paper); box-shadow: var(--shadow-2); }
.regional__label {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--ink-3);
}
.regional__name {
