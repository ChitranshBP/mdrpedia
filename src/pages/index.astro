}

/* ── CTA ── */
.cta { padding: 80px 0 96px; text-align: center; }
.cta h2 { font-size: clamp(40px, 5vw, 72px); font-weight: 300; max-width: 16ch; margin: 0 auto; }
.cta h2 em { font-style: italic; color: var(--ink-3); font-weight: 300; }
.cta__actions { margin-top: 32px; display:flex; gap: 12px; justify-content: center; }

@media (max-width: 900px) {
  .hero__lede, .hero__stats { grid-template-columns: 1fr; }
  .hero__stats { border-left: 0; margin-top: 32px; }
  .hero__stat { border-right: 0; padding: 12px 0; border-top: 1px solid var(--rule); }
  .roll, .dirs, .pillars, .regional__grid { grid-template-columns: 1fr 1fr; }
  .ethics-hero { grid-template-columns: 1fr; padding: 40px 24px; }
  .ed { grid-template-columns: 1fr; gap: 24px; padding: 64px 0; }
  .ledger__row { grid-template-columns: 80px 1fr 60px; gap: 8px; font-size: 11px; }
  .ledger__row > :nth-child(4), .ledger__row > :nth-child(5) { display: none; }
  .sec { padding: 64px 0; }
  .hero__masthead { flex-direction: column; gap: 4px; }
  .cta__actions { flex-direction: column; align-items: center; }
}

@media (max-width: 600px) {
  .roll, .pillars, .regional__grid { grid-template-columns: 1fr; }
  .dirs { grid-template-columns: 1fr; }
  .hero h1 { font-size: clamp(40px, 12vw, 56px); }
  .ethics-hero__seals { gap: 12px; }
}
</style>

<script define:vars={{ searchIndex }}>
  // Today's date
  const d = new Date();
  const dateEl = document.getElementById('hero-date');
  if (dateEl) dateEl.textContent = d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

  // Count-up animation
  const ease = t => 1 - Math.pow(1 - t, 3);
  const startCount = (el) => {
    const target = +el.dataset.count;
    if (!target) return;
    const dur = 1400;
    const t0 = performance.now();
    const step = (now) => {
      const p = Math.min(1, (now - t0) / dur);
      el.textContent = Math.round(target * ease(p)).toLocaleString();
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };
  const countObserver = new IntersectionObserver(es => es.forEach(e => {
    if (e.isIntersecting && !e.target.dataset.done) {
      e.target.dataset.done = '1';
      startCount(e.target);
    }
  }));
  document.querySelectorAll('[data-count]').forEach(el => countObserver.observe(el));

  // Reveal on scroll
  const revealObserver = new IntersectionObserver(es => es.forEach(e => {
    if (e.isIntersecting) e.target.classList.add('in');
  }), { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  // Hero search → open global search modal
  const heroSearch = document.getElementById('hero-search');
  if (heroSearch) {
    heroSearch.addEventListener('focus', () => {
      heroSearch.blur();
      document.dispatchEvent(new KeyboardEvent('keydown', {
        key: 'k', code: 'KeyK', metaKey: true, ctrlKey: false, bubbles: true
      }));
    });
  }
</script>
