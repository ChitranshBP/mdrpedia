.pillar .bar::after { content: ""; position:absolute; left: 0; top: 0; height: 100%; background: var(--ink); width: var(--w, 80%); }

/* ── DIRECTORIES ── */
.dirs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
