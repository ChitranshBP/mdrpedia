.dir__tag { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-3); }
.dir h3 { font-size: 28px; font-weight: 400; font-family: var(--font-serif); }
.dir p { font-size: 13px; color: inherit; opacity: 0.8; }
.dir__meta { display:flex; gap: 12px; font-family: var(--font-mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.08em; text-transform: uppercase; margin-top: auto; padding-top: 20px; border-top: 1px solid currentColor; }
.dir__n { font-weight: 600; color: var(--ink); }

/* ── LEDGER ── */
.ledger { padding: 64px 0; background: var(--paper-2); border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); margin-top: 64px; }
.ledger__head { display:flex; justify-content: space-between; align-items:center; margin-bottom: 32px; }
.ledger__head h3 { font-size: 22px; font-weight: 400; font-family: var(--font-serif); }
.ledger__head .live { display:inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 10px; color: var(--verdant); letter-spacing: 0.18em; text-transform: uppercase; }
.ledger__head .live .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--verdant); animation: pulse 1.8s infinite; }
.ledger__list { display:flex; flex-direction: column; }
.ledger__row { display:grid; grid-template-columns: 120px 120px 1fr 1fr 120px; gap: 16px; padding: 14px 0; border-top: 1px solid var(--rule); font-family: var(--font-mono); font-size: 12px; }
.ledger__row.head { color: var(--ink-3); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; }
.ledger__row.head + .ledger__row { border-top: 1px solid var(--ink); }
.ledger__row .verdict { font-family: var(--font-sans); font-weight: 600; }
.ledger__row .verdict.v { color: var(--verdant); }
.ledger__row .verdict.r { color: var(--sanguine); }

/* ── EDITORIAL ── */
.ed { display: grid; grid-template-columns: 1fr 2fr; gap: 80px; padding: 96px 0; border-top: 1px solid var(--rule); }
.ed__side { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; color: var(--ink-3); text-transform: uppercase; }
.ed__body h2 { font-size: 48px; font-weight: 300; max-width: 16ch; margin-bottom: 24px; }
.ed__body h2 em { font-style: italic; color: var(--ink-3); font-weight: 300; }
.ed__body > p { font-family: var(--font-serif); font-size: 20px; line-height: 1.6; max-width: 60ch; margin-bottom: 16px; }
.ed__body > p.drop::first-letter { font-size: 68px; float: left; line-height: 0.82; padding: 6px 10px 0 0; font-weight: 300; color: var(--ink); }

/* ── REGIONAL NAMES ── */
.regional { padding: 96px 0; }
.regional__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.regional__card {
  padding: 40px; border: 1px solid var(--rule); background: var(--paper-2);
