---
/**
 * MDRPedia 2.0 — Homepage
 * Editorial / scholarly design with ethics programme
 * Database-first with static fallback
 */

import Layout from "../layouts/Layout.astro";
import SealRound from "../components/SealRound.astro";
import RecentlyViewed from "../components/RecentlyViewed";
import { getCollection } from "astro:content";
import { prisma } from "../lib/prisma";
import { getTierCounts, getCountryStats, getFeaturedTitans, getSpecialtyStats } from "../lib/cached-stats";

export const prerender = false;

type FeaturedTitan = {
	slug: string;
	full_name: string;
	specialty: string;
	sub_specialty: string | null;
	tier: string;
	portrait_url: string | null;
	h_index: number | null;
	geography: { country: string; city: string | null } | null;
};

let tierCounts = { titan: 0, elite: 0, master: 0, unranked: 0, total: 0 };
let countriesCount = 0;
let featuredTitans: FeaturedTitan[] = [];
let specialtyCount = 0;

type DoctorData = {
	slug: string;
	fullName: string;
	specialty: string;
	subSpecialty?: string;
	tier: string;
	country: string;
	city?: string;
	portraitUrl: string | null;
	hIndex?: number;
};

let allDoctors: DoctorData[] = [];

try {
	const [cachedTierCounts, countryStats, cachedFeaturedTitans, specialtyStats] = await Promise.all([
		getTierCounts(),
		getCountryStats(),
		getFeaturedTitans(8),
		getSpecialtyStats(),
	]);

	tierCounts = cachedTierCounts;
	countriesCount = countryStats.length;
	featuredTitans = cachedFeaturedTitans;
	specialtyCount = specialtyStats.length;

	const dbDoctors = await prisma.profile.findMany({
		select: {
			slug: true,
			full_name: true,
			specialty: true,
			sub_specialty: true,
			tier: true,
			portrait_url: true,
			h_index: true,
			geography: { select: { country: true, city: true } },
		},
	});

	if (dbDoctors.length > 0) {
		allDoctors = dbDoctors.map((d) => ({
			slug: d.slug,
			fullName: d.full_name,
			specialty: d.specialty,
			subSpecialty: d.sub_specialty || undefined,
			tier: d.tier,
			country: d.geography?.country || "Unknown",
			city: d.geography?.city || undefined,
			portraitUrl: d.portrait_url,
			hIndex: d.h_index || undefined,
		}));
	} else {
		throw new Error("No profiles in database");
	}
} catch (e) {
	// Fallback to static content when DB is unavailable
	const staticDoctors = await getCollection("doctors");
	allDoctors = staticDoctors.map((d) => ({
		slug: d.id,
		fullName: d.data.fullName,
		specialty: d.data.specialty,
		subSpecialty: (d.data as any).subSpecialty || undefined,
		tier: d.data.tier || "UNRANKED",
		country: d.data.geography?.country || "Unknown",
		city: d.data.geography?.city || undefined,
		portraitUrl: d.data.portraitUrl || null,
		hIndex: (d.data as any).hIndex || undefined,
	}));

	tierCounts = {
		titan: allDoctors.filter((d) => d.tier === "TITAN").length,
		elite: allDoctors.filter((d) => d.tier === "ELITE").length,
		master: allDoctors.filter((d) => d.tier === "MASTER").length,
		unranked: allDoctors.filter((d) => d.tier === "UNRANKED").length,
		total: allDoctors.length
	};
	const countrySet = new Set(allDoctors.map((d) => d.country));
	countriesCount = countrySet.size;
	specialtyCount = new Set(allDoctors.map((d) => d.specialty)).size;
}

// Get initials from name
function getInitials(name: string): string {
	return name.split(' ').filter(Boolean).map(n => n[0]).join('').slice(0, 2).toUpperCase();
}

// Verification Ledger — real data from AdminLog + ProfileEdit
type LedgerEntry = { time: string; type: string; subject: string; evidence: string; verdict: string; positive: boolean };
let ledgerEntries: LedgerEntry[] = [];
try {
	const [logs, edits] = await Promise.all([
		prisma.adminLog.findMany({ orderBy: { createdAt: 'desc' }, take: 4 }),
		prisma.profileEdit.findMany({
			where: { status: 'APPROVED' },
			orderBy: { createdAt: 'desc' },
			take: 2,
		}),
	]);
	for (const log of logs) {
		const t = log.createdAt;
		const hh = String(t.getHours()).padStart(2, '0');
		const mm = String(t.getMinutes()).padStart(2, '0');
		ledgerEntries.push({
			time: `${hh}:${mm}`,
			type: log.action.replace(/_/g, ' ').toLowerCase().replace(/\b\w/g, c => c.toUpperCase()),
			subject: log.target,
			evidence: log.details ? JSON.parse(log.details).reason || 'Admin action' : 'Admin action',
			verdict: '\u2713 Applied',
			positive: true,
		});
	}
	for (const edit of edits) {
		const t = edit.createdAt;
		const hh = String(t.getHours()).padStart(2, '0');
		const mm = String(t.getMinutes()).padStart(2, '0');
		ledgerEntries.push({
			time: `${hh}:${mm}`,
			type: 'Correction',
			subject: `${edit.field_name} updated — ${edit.profile_slug}`,
			evidence: `${edit.contributor_name} · ${edit.reason || 'community edit'}`,
			verdict: '\u2713 Approved',
			positive: true,
		});
	}
	ledgerEntries.sort((a, b) => b.time.localeCompare(a.time));
	ledgerEntries = ledgerEntries.slice(0, 6);
} catch {}
const hasLedgerData = ledgerEntries.length > 0;

// Search index for inline search
const searchIndex = allDoctors.slice(0, 800).map(d => ({
	s: d.slug, n: d.fullName, sp: d.specialty,
	t: d.tier, c: d.country, ci: d.city || '',
	p: d.portraitUrl || '', h: d.hIndex || 0,
}));

// Ethics count from database
let ethicsCount = 0;
try {
	ethicsCount = await prisma.profile.count({ where: { ethics_tier: { not: null } } });
} catch {
	ethicsCount = 0;
}

Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=120, stale-while-revalidate=300');
---

<Layout title="MDRPedia — The Physicians' Register">

<!-- HERO -->
<section class="hero container">
	<div class="hero__masthead">
		<span class="edition">Vol. II &middot; Edition 2026-04 &middot; The Physicians' Register</span>
		<span class="edition">Open Encyclopedia &middot; CC-BY-SA &middot; <span id="hero-date"></span></span>
	</div>

	<h1 class="reveal">A record of<br><em>who practices medicine —</em><br>and how they practice it.</h1>

	<div class="hero__lede">
		<p>
			MDRPedia is an independently-verified encyclopedia of {tierCounts.total.toLocaleString()} physicians across {countriesCount} countries. Every profile is built from primary sources — journals, registries, institutions — and carries a single, revocable mark of stature. In 2026, it earned a second mark: <strong>Ethics</strong>.
		</p>
		<div class="hero__stats">
			<div class="hero__stat"><div class="n tnum" data-count={tierCounts.total}>{tierCounts.total.toLocaleString()}</div><div class="l">Verified Profiles</div></div>
			<div class="hero__stat"><div class="n tnum" data-count={countriesCount}>{countriesCount}</div><div class="l">Countries</div></div>
			<div class="hero__stat"><div class="n tnum" data-count={tierCounts.titan}>{tierCounts.titan}</div><div class="l">Titans &middot; Tier I</div></div>
			<div class="hero__stat"><div class="n tnum" data-count={ethicsCount}>{ethicsCount}</div><div class="l">Ethics Legends</div></div>
		</div>
	</div>

	<div class="command">
		<label class="command__bar">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
			<input id="hero-search" placeholder={`Search ${tierCounts.total.toLocaleString()} profiles by name, specialty, institution, DOI...`} autocomplete="off" />
			<kbd class="mono" style="font-size:10px; padding:3px 6px; border:1px solid var(--rule); border-radius:3px; color:var(--ink-3);">&#8984;K</kbd>
		</label>
		<div class="command__facets">
			<button class="facet">Specialty <span class="count">{specialtyCount}</span></button>
			<button class="facet">Country <span class="count">{countriesCount}</span></button>
			<button class="facet">Tier</button>
			<button class="facet">Ethics <span class="count">{ethicsCount}</span></button>
			<button class="facet">Institution</button>
			<button class="facet">Mentorship Lineage</button>
			<button class="facet">Rare Disease</button>
		</div>
	</div>
</section>

<!-- RECENTLY VIEWED (client-only, renders only if localStorage has entries) -->
<div class="container" style="padding-top: var(--s-6);">
	<RecentlyViewed client:load />
</div>

<!-- ETHICAL DOCTORS — new section -->
<section class="container">
	<div class="ethics-hero reveal">
		<div>
			<span class="new-mark"><span class="dot"></span>New &middot; 2026 Programme</span>
			<h2>Merit is one register.<br><em>Integrity is another.</em></h2>
			<p>Stature tells you how much a doctor knows. The <strong>Ethics Register</strong> tells you how they practice. It's independently verified, publicly revocable, and — for the first time — embeddable on their own clinic website. A seal they earn, and a promise they sign.</p>
			<div class="ethics-hero__actions">
				<a href="/ethical-doctors" class="btn btn--verdant">Enter the Ethics Register &rarr;</a>
				<a href="/doctor/claim" class="btn btn--ghost">Nominate a Doctor</a>
			</div>
		</div>
		<div class="ethics-hero__seals">
			<div><SealRound kind="legend" id="E-001" size={160} /></div>
			<div><SealRound kind="guardian" id="E-044" size={130} /></div>
			<div><SealRound kind="advocate" id="E-215" size={110} /></div>
		</div>
	</div>
</section>

<!-- FEATURED TITANS -->
<section class="sec container">
	<div class="sec-head">
		<div class="sec-head__left">
			<span class="num">&sect; 01</span>
			<h2>The <em>Titans</em></h2>
		</div>
		<div class="sec-head__right">{tierCounts.titan} profiles &middot; <a href="/rankings">the complete register &rarr;</a></div>
	</div>
	<div class="roll">
		{featuredTitans.slice(0, 8).map(titan => (
			<a class="roll__card" href={`/doctors/${titan.slug}`}>
				<div class="roll__portrait">
					{titan.portrait_url ? (
						<img src={titan.portrait_url} alt={titan.full_name} loading="lazy" width="88" height="88" class="roll__img" />
					) : (
						<div class="pp">{getInitials(titan.full_name)}</div>
					)}
				</div>
				<div>
					<h3>{titan.full_name}</h3>
					<div class="spec">{titan.specialty}{titan.sub_specialty ? ` \u00B7 ${titan.sub_specialty}` : ''}</div>
				</div>
				<div class="meta">
					<span>{titan.geography?.city ? `${titan.geography.city}, ` : ''}{titan.geography?.country || 'Unknown'}</span>
					<strong>h-index {titan.h_index || '—'}</strong>
				</div>
			</a>
		))}
		{/* Fill empty slots if fewer than 8 titans */}
		{featuredTitans.length < 8 && Array.from({ length: Math.min(8 - featuredTitans.length, 4) }).map((_, i) => (
			<a class="roll__card" href="/rankings" style="opacity:0.5;">
				<div class="roll__portrait"><div class="pp">?</div></div>
				<div>
					<h3>View More</h3>
					<div class="spec">Browse the full register</div>
				</div>
				<div class="meta"><span>&nbsp;</span><strong>&rarr;</strong></div>
			</a>
		))}
	</div>
</section>

<!-- PILLARS -->
<section class="sec container">
	<div class="sec-head">
		<div class="sec-head__left">
			<span class="num">&sect; 02</span>
			<h2>How a tier <em>is decided</em></h2>
		</div>
		<div class="sec-head__right">Methodology v2.0</div>
	</div>
	<div class="pillars">
		<div class="pillar"><div class="num">01</div><h3>Clinical Mastery</h3><p>Case volume in high-acuity interventions, complication rates, board certifications, registries.</p><div class="metric">Weight 30%<div class="bar" style="--w: 30%"></div></div></div>
		<div class="pillar"><div class="num">02</div><h3>Intellectual Legacy</h3><p>H-index, landmark trials, textbook authorship, changes to clinical guidelines.</p><div class="metric">Weight 30%<div class="bar" style="--w: 30%"></div></div></div>
		<div class="pillar"><div class="num">03</div><h3>Mentorship</h3><p>Tracked lineage of trainees and what they went on to do. Legacy reproduced.</p><div class="metric">Weight 20%<div class="bar" style="--w: 20%"></div></div></div>
		<div class="pillar"><div class="num">04</div><h3>Humanitarian Impact</h3><p>Global health, disaster work, free clinics, care for the underserved.</p><div class="metric">Weight 20%<div class="bar" style="--w: 20%"></div></div></div>
	</div>
</section>

<!-- DIRECTORIES -->
<section class="sec container">
	<div class="sec-head">
		<div class="sec-head__left">
			<span class="num">&sect; 03</span>
			<h2>The <em>register</em> of records</h2>
		</div>
		<div class="sec-head__right">Seven adjacent encyclopedias</div>
	</div>
	<div class="dirs">
		<a class="dir" href="/doctors"><span class="dir__tag">Directory 01</span><h3>Physicians</h3><p>Every verified doctor, living or historical, with full dossier and ethics record.</p><div class="dir__meta"><span>{tierCounts.total.toLocaleString()} profiles</span><span class="dir__n">&nearr;</span></div></a>
		<a class="dir" href="/ethical-doctors"><span class="dir__tag">Directory 02</span><h3>Ethical Doctors</h3><p>The register of integrity — Legends, Guardians, and Advocates of ethical practice.</p><div class="dir__meta"><span>{ethicsCount} seals</span><span class="dir__n">&nearr;</span></div></a>
		<a class="dir" href="/rankings"><span class="dir__tag">Directory 03</span><h3>Rankings</h3><p>By specialty, country, institution, and the four pillars of verification.</p><div class="dir__meta"><span>{specialtyCount} specialties</span><span class="dir__n">&nearr;</span></div></a>
		<a class="dir" href="/institutions"><span class="dir__tag">Directory 04</span><h3>Institutions</h3><p>Hospitals, research centers, and centers of excellence — ranked and mapped.</p><div class="dir__meta"><span>Hospitals</span><span class="dir__n">&nearr;</span></div></a>
		<a class="dir" href="/rare-diseases"><span class="dir__tag">Directory 05</span><h3>Rare Diseases</h3><p>Conditions and the physicians verified to treat them, by country.</p><div class="dir__meta"><span>Conditions</span><span class="dir__n">&nearr;</span></div></a>
		<a class="dir" href="/clinical-trials"><span class="dir__tag">Directory 06</span><h3>Clinical Trials</h3><p>Active trials, investigators, and the lineage of evidence they produce.</p><div class="dir__meta"><span>Trials</span><span class="dir__n">&nearr;</span></div></a>
	</div>
</section>

<!-- VERIFICATION LEDGER -->
<section class="ledger">
	<div class="container">
		<div class="ledger__head">
			<h3>The Verification Ledger</h3>
			{hasLedgerData ? (
				<span class="live"><span class="dot"></span>Recent activity</span>
			) : (
				<span class="live">Sample data</span>
			)}
		</div>
		<div class="ledger__list">
			<div class="ledger__row head"><span>Time</span><span>Type</span><span>Subject</span><span>Evidence</span><span>Verdict</span></div>
			{hasLedgerData ? (
				ledgerEntries.map(entry => (
					<div class="ledger__row">
						<span>{entry.time}</span>
						<span>{entry.type}</span>
						<span>{entry.subject}</span>
						<span>{entry.evidence}</span>
						<span class={`verdict ${entry.positive ? 'v' : 'r'}`}>{entry.verdict}</span>
					</div>
				))
			) : (
				<div class="ledger__row"><span></span><span></span><span>No recent activity recorded.</span><span></span><span></span></div>
			)}
		</div>
	</div>
</section>

<!-- EDITORIAL -->
<section class="ed container">
	<div class="ed__side">
		On the <br>Editorial <br>Mission
	</div>
	<div class="ed__body">
		<h2>Why build an <em>encyclopedia</em> and not another directory?</h2>
		<p class="drop">Directories rank doctors. Review sites count stars. Insurance portals list contracts. None of those answer the question a patient, a researcher, or a hospital actually asks: <em>what did this person do, and does it hold up?</em></p>
		<p>MDRPedia is built as a work of record. Every claim is sourced. Every source is citable. Every tier is revocable. And starting in 2026, every doctor also has an Ethics file — a separate, public ledger of how they practice, which any of us can nominate into, and any of us can scrutinize. It is not the faster way to find a doctor. It is the truer one.</p>
		<p><a href="/about">Read the full editorial &rarr;</a></p>
	</div>
</section>

<!-- REGIONAL NAMES -->
<section class="regional container">
	<div class="sec-head">
		<div class="sec-head__left">
			<span class="num">&sect; 04</span>
			<h2>One register, <em>two names</em></h2>
		</div>
		<div class="sec-head__right"><a href="/about/our-name">the full story &rarr;</a></div>
	</div>
	<div class="regional__grid">
		<a href="/about/mdpedia" class="regional__card">
			<div class="regional__label">In the West</div>
			<div class="regional__name">MDpedia</div>
			<div class="regional__origin">From "MD" — Doctor of Medicine</div>
			<p>Across the Americas, Europe, and Australasia, physicians shortened our name to reflect their primary credential. MDpedia is how the register is known in hospitals from Boston to Berlin.</p>
			<div class="regional__tags">
				<span>Americas</span><span>Europe</span><span>Australasia</span>
			</div>
		</a>
		<a href="/about/drpedia" class="regional__card">
			<div class="regional__label">In the East</div>
			<div class="regional__name">DRpedia</div>
			<div class="regional__origin">From "Dr." — the universal honorific</div>
			<p>Across the Middle East, South Asia, East Asia, and Africa, the platform became DRpedia — honouring the title that binds physicians from Cairo to Shanghai.</p>
			<div class="regional__tags">
				<span>Middle East</span><span>South Asia</span><span>East Asia</span><span>Africa</span>
			</div>
		</a>
	</div>
</section>

<!-- CTA -->
<section class="cta container">
	<span class="eyebrow">Claim &middot; Embed &middot; Nominate</span>
	<h2 style="margin-top:16px;">If your record is here, <em>own it.</em><br>If a doctor earned the seal, <em>give them one.</em></h2>
	<div class="cta__actions">
		<a href="/doctor/claim" class="btn btn--primary">Claim your profile</a>
		<a href="/doctor/claim" class="btn btn--ghost">Get the embed kit</a>
		<a href="/doctor/claim" class="btn btn--ghost" style="border-color: var(--verdant); color: var(--verdant);">Nominate for Ethics</a>
	</div>
</section>

</Layout>

<style>
/* ── HERO ── */
.hero { padding: 80px 0 40px; position: relative; }
.hero__masthead { display:flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid var(--ink); padding-bottom: 8px; margin-bottom: 40px; }
.hero__masthead .edition { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-3); }
.hero h1 { font-size: clamp(56px, 9vw, 140px); font-weight: 300; line-height: 0.92; letter-spacing: -0.03em; }
.hero h1 em { font-style: italic; color: var(--ink-3); font-weight: 300; }
.hero__lede { display:grid; grid-template-columns: 1fr 1fr; gap: 64px; margin-top: 40px; align-items: end; }
.hero__lede p { font-family: var(--font-serif); font-size: 22px; line-height: 1.45; color: var(--ink); font-weight: 400; max-width: 40ch; }
.hero__lede p::first-letter { font-size: 64px; float: left; line-height: 0.82; padding: 6px 10px 0 0; font-weight: 300; }
.hero__stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-left: 1px solid var(--rule); }
.hero__stat { padding-left: 20px; border-right: 1px solid var(--rule); padding-right: 20px; }
.hero__stat:last-child { border-right: 0; }
.hero__stat .n { font-family: var(--font-serif); font-size: 40px; font-weight: 400; line-height: 1; font-variant-numeric: tabular-nums; }
.hero__stat .l { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); margin-top: 6px; }

/* ── SEARCH ── */
.command {
  margin-top: 64px; background: var(--paper-2); border: 1px solid var(--rule);
  border-radius: var(--r-3); padding: 8px;
}
.command__bar { display:flex; align-items:center; gap: 12px; padding: 16px 20px; background: var(--paper); border-radius: var(--r-2); border: 1px solid var(--rule); cursor: text; }
.command__bar input { flex: 1; border: 0; background: transparent; font-family: var(--font-serif); font-size: 22px; color: var(--ink); outline: none; }
.command__bar input::placeholder { color: var(--ink-3); }
.command__facets { display:flex; gap: 8px; padding: 10px 12px 4px; flex-wrap: wrap; }
.facet { display:inline-flex; align-items:center; gap: 6px; padding: 5px 10px; border: 1px solid var(--rule); border-radius: var(--r-pill); font-size: 12px; color: var(--ink-2); background: var(--paper); cursor: pointer; font-family: var(--font-sans); }
.facet:hover { border-color: var(--ink); color: var(--ink); }
.facet .count { font-family: var(--font-mono); font-size: 10px; color: var(--ink-3); }

/* ── ETHICS HERO ── */
.ethics-hero {
  margin-top: 96px; padding: 64px 48px; position: relative;
  background: var(--verdant-2);
  border: 1px solid color-mix(in oklch, var(--verdant) 40%, var(--rule));
  display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 64px; align-items: center;
  overflow: hidden;
}
.ethics-hero::before {
  content: ""; position: absolute; inset: 0;
  background-image:
    radial-gradient(circle at 20% 30%, color-mix(in oklch, var(--verdant) 20%, transparent) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, color-mix(in oklch, var(--guardian) 15%, transparent) 0%, transparent 40%);
  pointer-events: none;
}
.ethics-hero > * { position: relative; }
.ethics-hero h2 { font-size: clamp(36px, 4.5vw, 60px); font-weight: 300; }
.ethics-hero h2 em { font-style: italic; color: var(--verdant); font-weight: 300; }
.ethics-hero .new-mark { display:inline-flex; align-items:center; gap: 8px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--verdant); padding-bottom: 20px; }
.ethics-hero .new-mark .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--verdant); animation: pulse 2.2s infinite; }
