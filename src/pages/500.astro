---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
---

<Layout title="500 — Server Error | MDRPedia">
    <div class="error-page">
        <div class="error-content">
            <!-- Animated 500 -->
            <div class="error-code">
                <span class="digit">5</span>
                <span class="digit pulse">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 9v4M12 17h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
                    </svg>
                </span>
                <span class="digit">0</span>
            </div>

            <h1 class="error-title">Something Went Wrong</h1>
            <p class="error-description">
                Our servers encountered an unexpected error. The issue has been
                logged and our team has been notified. Please try again shortly.
            </p>

            <!-- Quick Actions -->
            <div class="error-actions">
                <a href="/" class="btn-primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                        <polyline points="9,22 9,12 15,12 15,22" />
                    </svg>
                    Return Home
                </a>
                <a href="/doctors" class="btn-secondary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
                    </svg>
                    Browse Doctors
                </a>
            </div>

            <!-- Help Box -->
            <div class="help-card">
                <div class="help-header">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 16v-4M12 8h.01" />
                    </svg>
                    <span>If this problem persists</span>
                </div>
                <p class="help-text">
                    Try refreshing the page, clearing your browser cache, or
                    <a href="/contact">contact our support team</a>.
                </p>
            </div>
        </div>
    </div>
</Layout>

<style>
    .error-page {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--s-9) var(--gutter);
    }

    .error-content {
        max-width: 540px;
        text-align: center;
    }

    .error-code {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--s-2);
        margin-bottom: var(--s-5);
    }

    .digit {
        font-family: var(--font-serif);
        font-size: 6rem;
        font-weight: 400;
        color: var(--ink);
        line-height: 1;
        animation: fadeIn 0.6s ease-out both;
    }

    .digit:nth-child(1) { animation-delay: 0.1s; }
    .digit:nth-child(3) { animation-delay: 0.3s; }

    .digit.pulse {
        width: 100px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--sanguine-2);
        border: 2px solid var(--sanguine);
        border-radius: var(--r-4);
        animation: fadeIn 0.6s ease-out 0.2s both;
    }

    .digit.pulse svg {
        width: 48px;
        height: 48px;
        color: var(--sanguine);
    }

    .error-title {
        font-family: var(--font-serif);
        font-weight: 400;
        color: var(--ink);
        margin: 0 0 var(--s-3);
        animation: fadeIn 0.6s ease-out 0.3s both;
    }

    .error-description {
        font-size: 1.1rem;
        color: var(--ink-2);
        line-height: 1.7;
        margin: 0 0 var(--s-6);
        animation: fadeIn 0.6s ease-out 0.4s both;
    }

    .error-actions {
        display: flex;
        gap: var(--s-3);
        justify-content: center;
        margin-bottom: var(--s-7);
        animation: fadeIn 0.6s ease-out 0.5s both;
    }

    .btn-primary,
    .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: var(--s-2);
        padding: 12px 20px;
        border-radius: var(--r-2);
        font-family: var(--font-sans);
        font-weight: 500;
        font-size: 14px;
        text-decoration: none;
        transition: all var(--t-fast) var(--ease);
    }

    .btn-primary {
        background: var(--ink);
        color: var(--paper);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-2);
    }

    .btn-secondary {
        background: transparent;
        border: 1px solid var(--ink);
        color: var(--ink);
    }

    .btn-secondary:hover {
        background: var(--ink);
        color: var(--paper);
        transform: translateY(-2px);
    }

    .btn-primary svg,
    .btn-secondary svg {
        width: 18px;
        height: 18px;
    }

    .help-card {
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
        padding: var(--s-5);
        animation: fadeIn 0.6s ease-out 0.6s both;
    }

    .help-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: var(--s-3);
        color: var(--ink);
        font-weight: 500;
    }

    .help-header svg {
        width: 18px;
        height: 18px;
        color: var(--sanguine);
    }

    .help-text {
        font-size: 0.95rem;
        color: var(--ink-2);
        line-height: 1.6;
        margin: 0;
    }

    .help-text a {
        color: var(--ink-blue);
    }

    @media (max-width: 768px) {
        .digit { font-size: 4rem; }
        .digit.pulse { width: 70px; height: 70px; }
        .digit.pulse svg { width: 32px; height: 32px; }
        .error-actions { flex-direction: column; }
    }
</style>
