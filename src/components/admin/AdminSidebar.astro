---
/**
 * AdminSidebar — Shared sidebar navigation for all admin pages
 */
interface Props {
    adminKey: string | null;
    activePage: string;
}

const { adminKey: rawKey, activePage } = Astro.props;
const adminKey = rawKey || "";

const navItems = [
    { id: "dashboard", label: "Dashboard", href: `/admin?key=${adminKey}`, icon: `<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>` },
    { id: "doctors", label: "All Doctors", href: `/admin/doctors?key=${adminKey}`, icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>` },
    { id: "pages", label: "CMS Pages", href: `/admin/pages?key=${adminKey}`, icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>` },
    { id: "news", label: "News", href: `/admin/news?key=${adminKey}`, icon: `<path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v1m2 13a2 2 0 0 1-2-2V7m2 13a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2"/>` },
    { id: "institutions", label: "Institutions", href: `/admin/institutions?key=${adminKey}`, icon: `<path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6"/>` },
    { id: "claims", label: "Claims", href: `/admin/claims?key=${adminKey}`, icon: `<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>` },
    { id: "ethics", label: "Ethics", href: `/admin/ethics?key=${adminKey}`, icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>` },
    { id: "edits", label: "Pending Edits", href: `/admin/edits?key=${adminKey}`, icon: `<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>` },
    { id: "submissions", label: "Submissions", href: `/admin/submissions?key=${adminKey}`, icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>` },
    { id: "editor", label: "Knowledge Graph", href: `/admin/editor?key=${adminKey}`, icon: `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/>` },
];

const toolItems = [
    { id: "audit-log", label: "Activity Log", href: `/admin/audit-log?key=${adminKey}`, icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>` },
    { id: "data-quality", label: "Data Quality", href: `/admin/data-quality?key=${adminKey}`, icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>` },
    { id: "bulk-import", label: "Bulk Import", href: `/admin/bulk-import?key=${adminKey}`, icon: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>` },
    { id: "analytics", label: "Analytics", href: `/admin/analytics?key=${adminKey}`, icon: `<path d="M18 20V10M12 20V4M6 20v-6"/>` },
    { id: "broken-links", label: "Broken Links", href: `/admin/broken-links?key=${adminKey}`, icon: `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/><line x1="4" y1="4" x2="20" y2="20" stroke="#ef4444"/>` },
];
---

<!-- Sidebar -->
<aside class="sidebar">
    <div class="sidebar__brand">
        <div class="brand-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6"></path>
            </svg>
        </div>
        <span class="brand-text">MDRPedia</span>
        <span class="brand-badge">Admin</span>
    </div>

    <nav class="sidebar__nav">
        {navItems.map(item => (
            <a href={item.href} class={`nav-item${activePage === item.id ? ' active' : ''}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <Fragment set:html={item.icon} />
                </svg>
                {item.label}
            </a>
        ))}

        <div class="nav-divider"></div>
        <span class="nav-section-label">Tools</span>

        {toolItems.map(item => (
            <a href={item.href} class={`nav-item${activePage === item.id ? ' active' : ''}`}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <Fragment set:html={item.icon} />
                </svg>
                {item.label}
            </a>
        ))}
    </nav>

    <div class="sidebar__footer">
        <a href="/" class="nav-item nav-item--muted">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            Exit Admin
        </a>
    </div>
</aside>

<!-- Mobile Header -->
<div class="mobile-header">
    <div class="mobile-brand">
        <div class="brand-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6"></path>
            </svg>
        </div>
        <span>MDRPedia Admin</span>
    </div>
    <nav class="mobile-nav">
        <a href={`/admin?key=${adminKey}`} class={`mobile-nav-link${activePage === 'dashboard' ? ' active' : ''}`}>Dashboard</a>
        <a href={`/admin/doctors?key=${adminKey}`} class={`mobile-nav-link${activePage === 'doctors' ? ' active' : ''}`}>Doctors</a>
        <a href={`/admin/pages?key=${adminKey}`} class={`mobile-nav-link${activePage === 'pages' ? ' active' : ''}`}>Pages</a>
        <a href={`/admin/news?key=${adminKey}`} class={`mobile-nav-link${activePage === 'news' ? ' active' : ''}`}>News</a>
        <a href={`/admin/ethics?key=${adminKey}`} class={`mobile-nav-link${activePage === 'ethics' ? ' active' : ''}`}>Ethics</a>
        <a href={`/admin/edits?key=${adminKey}`} class={`mobile-nav-link${activePage === 'edits' ? ' active' : ''}`}>Edits</a>
        <a href="/" class="mobile-nav-link">Exit</a>
    </nav>
</div>

<style is:global>
    /* Admin Layout */
    .admin {
        display: flex;
        min-height: 100vh;
        background: var(--paper);
    }

    /* Sidebar */
    .sidebar {
        width: 240px;
        background: var(--paper-2);
        border-right: 1px solid var(--rule);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        height: 100vh;
        z-index: 50;
    }

    .sidebar__brand {
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid var(--rule);
    }

    .brand-icon {
        width: 32px;
        height: 32px;
        background: var(--ink-blue);
        border-radius: var(--r-3);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .brand-icon svg {
        width: 18px;
        height: 18px;
    }

    .brand-text {
        font-weight: 500;
        font-size: 1rem;
        color: var(--ink);
    }

    .brand-badge {
        font-size: 0.6rem;
        font-weight: 600;
        padding: 2px 6px;
        background: var(--sanguine-2);
        color: var(--sanguine);
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .sidebar__nav {
        flex: 1;
        padding: 16px 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        overflow-y: auto;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: var(--r-3);
        color: var(--ink-2);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.15s;
    }

    .nav-item svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
    }

    .nav-item:hover {
        background: var(--paper-3);
        color: var(--ink);
    }

    .nav-item.active {
        background: var(--ink-blue-2);
        color: var(--ink-blue);
    }

    .nav-item--muted {
        color: var(--ink-3);
    }

    .nav-divider {
        height: 1px;
        background: var(--rule);
        margin: 12px 0 8px;
    }

    .nav-section-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 600;
        color: var(--ink-3);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 0 12px;
        margin-bottom: 8px;
    }

    .sidebar__footer {
        padding: 16px 12px;
        border-top: 1px solid var(--rule);
    }

    /* Main Content Area */
    .admin > .main {
        flex: 1;
        margin-left: 240px;
        padding: 24px 32px;
        min-height: 100vh;
    }

    /* Mobile Header */
    .mobile-header {
        display: none;
        flex-direction: column;
        gap: 16px;
        padding: 16px 0;
        margin-bottom: 16px;
        border-bottom: 1px solid var(--rule);
    }

    .mobile-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 500;
        color: var(--ink);
    }

    .mobile-brand .brand-icon {
        width: 32px;
        height: 32px;
        background: var(--ink-blue);
        border-radius: var(--r-3);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .mobile-brand .brand-icon svg {
        width: 18px;
        height: 18px;
    }

    .mobile-nav {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .mobile-nav-link {
        padding: 8px 14px;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--ink-2);
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
        text-decoration: none;
        transition: all 0.15s;
    }

    .mobile-nav-link:hover {
        background: var(--paper-3);
        color: var(--ink);
    }

    .mobile-nav-link.active {
        background: var(--ink-blue-2);
        border-color: var(--ink-blue);
        color: var(--ink-blue);
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .sidebar {
            display: none;
        }
        .admin > .main {
            margin-left: 0;
        }
        .mobile-header {
            display: flex;
        }
    }

    @media (max-width: 768px) {
        .admin > .main {
            padding: 16px;
        }
    }
</style>
