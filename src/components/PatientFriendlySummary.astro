---
/**
 * MDRPedia — Patient-Friendly Summary
 * Plain-language bullet points for non-medical audiences
 */
import { generatePatientSummary, type PatientBullet } from '../lib/patient-summary';
import type { ProfileData } from '../lib/types';

interface Props {
    doctor: ProfileData;
    totalCitations: number;
}

const { doctor, totalCitations } = Astro.props;

const bullets = generatePatientSummary({
    fullName: doctor.fullName,
    specialty: doctor.specialty,
    subSpecialty: doctor.subSpecialty,
    yearsActive: doctor.yearsActive,
    verifiedSurgeries: doctor.verifiedSurgeries,
    livesSaved: doctor.livesSaved,
    techniquesInvented: doctor.techniquesInvented || [],
    hIndex: doctor.hIndex,
    totalCitations,
    geography: {
        country: doctor.geography.country,
        region: doctor.geography.region,
        city: doctor.geography.city,
    },
    affiliations: doctor.affiliations?.map(a => ({
        hospitalName: a.hospitalName,
        role: a.role,
    })),
    status: doctor.status,
    dateOfBirth: doctor.dateOfBirth,
    dateOfDeath: doctor.dateOfDeath,
});

const show = bullets.length >= 2;
---

{show && (
    <section class="patient-summary">
        <h3 class="patient-summary__title">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 00-3-3.87" /><path d="M16 3.13a4 4 0 010 7.75" />
            </svg>
            For Patients
        </h3>
        <ul class="patient-summary__list">
            {bullets.map((bullet: PatientBullet) => (
                <li class="patient-summary__item">
                    <svg class="patient-summary__icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path d={bullet.icon} />
                    </svg>
                    <span>{bullet.text}</span>
                </li>
            ))}
        </ul>
    </section>
)}

<style>
    .patient-summary {
        margin-top: var(--space-lg);
        padding: var(--space-lg);
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
        border-left: 3px solid var(--ink-blue);
    }

    .patient-summary__title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--ink);
        margin: 0 0 var(--space-md);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .patient-summary__title svg {
        color: var(--ink-blue);
    }

    .patient-summary__list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .patient-summary__item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        font-size: 0.88rem;
        line-height: 1.5;
        color: var(--ink-2);
    }

    .patient-summary__icon {
        flex-shrink: 0;
        margin-top: 2px;
        color: var(--ink-3);
    }
</style>
