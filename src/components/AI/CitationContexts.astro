---
/**
 * CitationContexts - Dense Citation Context Display
 * Shows WHY papers were cited, not just citation counts
 */

import type { CitationContextSummary, CitationContext } from '../../lib/ai-content-types';
import { CITATION_REASON_LABELS } from '../../lib/ai-content-types';

interface Props {
    summary: CitationContextSummary;
    doctorName: string;
    tier?: string;
}

const { summary, doctorName, tier = 'UNRANKED' } = Astro.props;

// Impact category config
const impactConfig: Record<CitationContext['impactCategory'], { label: string; color: string }> = {
    SEMINAL: { label: 'Seminal', color: '#ffd700' },
    SIGNIFICANT: { label: 'Significant', color: '#10b981' },
    SUPPORTING: { label: 'Supporting', color: '#3b82f6' },
    MINOR: { label: 'Minor', color: '#6b7280' },
};

// Reason icons
const reasonIcons: Record<CitationContext['citationReason'], string> = {
    METHODOLOGY: '<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M9 3h6v2H9V3zm0 4v6l-3 6h12l-3-6V7H9z"/></svg>',
    FOUNDATION: '<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>',
    COMPARISON: '<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M12 3v18M3 12l4-4v8l-4-4zM21 12l-4-4v8l4-4z"/></svg>',
    VALIDATION: '<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>',
    EXTENSION: '<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
    CRITICISM: '<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
    CLINICAL_APPLICATION: '<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-4h6v4M12 7v4M10 9h4"/></svg>',
};
---

<section class={`citation-context-section tier-${tier.toLowerCase()}`}>
    <div class="section-header">
        <h2 class="section-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            Citation Impact Analysis
        </h2>
        <span class="total-badge">{summary.totalCitations.toLocaleString()} citations analyzed</span>
    </div>

    <!-- Citation Reasons Breakdown -->
    <div class="reasons-grid">
        {Object.entries(summary.citationsByReason).map(([reason, count]) => (
            <div class="reason-card">
                <span class="reason-icon" set:html={reasonIcons[reason as CitationContext['citationReason']]}></span>
                <div class="reason-content">
                    <span class="reason-count">{count.toLocaleString()}</span>
                    <span class="reason-label">{CITATION_REASON_LABELS[reason as CitationContext['citationReason']]}</span>
                </div>
            </div>
        ))}
    </div>

    <!-- Seminal Citations (Most Important) -->
    {summary.seminalCitations.length > 0 && (
        <div class="seminal-section">
            <h3 class="subsection-title">
                <span class="subsection-icon"><svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
                Seminal Citations
                <span class="help-text">Work that fundamentally shaped the field</span>
            </h3>
            <div class="citations-list">
                {summary.seminalCitations.slice(0, 5).map(citation => (
                    <div class="citation-card seminal">
                        <div class="citation-header">
                            <span class={`impact-badge ${citation.impactCategory.toLowerCase()}`}>
                                {impactConfig[citation.impactCategory].label}
                            </span>
                            <span class="citation-year">{citation.citingPaperYear}</span>
                        </div>
                        <p class="citing-paper">{citation.citingPaperTitle}</p>
                        <blockquote class="citation-context">
                            "{citation.citationContext}"
                        </blockquote>
                        <div class="citation-meta">
                            <span class="reason-tag">
                                <Fragment set:html={reasonIcons[citation.citationReason]} /> {CITATION_REASON_LABELS[citation.citationReason]}
                            </span>
                            {citation.journalName && (
                                <span class="journal-name">{citation.journalName}</span>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    )}

    <!-- Top Citing Papers -->
    {summary.topCitingPapers.length > 0 && (
        <div class="top-citations-section">
            <h3 class="subsection-title">
                <span class="subsection-icon"><svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M18 20V10M12 20V4M6 20v-6"/></svg></span>
                Notable Citing Papers
            </h3>
            <div class="citations-list compact">
                {summary.topCitingPapers.slice(0, 8).map(citation => (
                    <div class="citation-card compact">
                        <div class="citation-header">
                            <span class={`impact-badge small ${citation.impactCategory.toLowerCase()}`}>
                                {impactConfig[citation.impactCategory].label}
                            </span>
                            <span class="reason-tag small" set:html={reasonIcons[citation.citationReason]}>
                            </span>
                        </div>
                        <p class="citing-paper">{citation.citingPaperTitle}</p>
                        <span class="citation-year">{citation.citingPaperYear}</span>
                    </div>
                ))}
            </div>
        </div>
    )}

    <!-- Yearly Trend -->
    {summary.yearlyTrend && summary.yearlyTrend.length > 0 && (
        <div class="trend-section">
            <h3 class="subsection-title">
                <span class="subsection-icon"><svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M23 6l-9.5 9.5-5-5L1 18"/></svg></span>
                Citation Trend
            </h3>
            <div class="trend-bars">
                {summary.yearlyTrend.slice(-10).map(entry => {
                    const maxCount = Math.max(...summary.yearlyTrend!.map(e => e.count));
                    const height = (entry.count / maxCount) * 100;
                    return (
                        <div class="trend-bar-container">
                            <div class="trend-bar" style={`height: ${height}%;`}>
                                <span class="bar-value">{entry.count}</span>
                            </div>
                            <span class="bar-year">{entry.year}</span>
                        </div>
                    );
                })}
            </div>
        </div>
    )}

    <!-- Hidden semantic layer for AI -->
    <div class="ai-semantic-layer" aria-hidden="true" style="display:none;">
        <h3>Citation Context Analysis for {doctorName}</h3>
        <p>Total citations analyzed: {summary.totalCitations}</p>
        <h4>Citations by Reason:</h4>
        <ul>
            {Object.entries(summary.citationsByReason).map(([reason, count]) => (
                <li>{CITATION_REASON_LABELS[reason as CitationContext['citationReason']]}: {count}</li>
            ))}
        </ul>
        <h4>Seminal Works:</h4>
        {summary.seminalCitations.map(c => (
            <p>"{c.citationContext}" — cited in {c.citingPaperTitle} ({c.citingPaperYear}) for {CITATION_REASON_LABELS[c.citationReason]}</p>
        ))}
    </div>
</section>

<style>
    .citation-context-section {
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-4);
        padding: 2rem;
        margin-bottom: 2rem;
        
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--rule);
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.25rem;
        font-weight: 500;
        margin: 0;
        color: var(--ink);
    }

    .section-title svg {
        color: var(--aged-gold);
        opacity: 0.9;
    }

    .total-badge {
        padding: 4px 12px;
        background: rgba(245, 158, 11, 0.15);
        border-radius: var(--r-pill);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--aged-gold);
    }

    /* Reasons Grid */
    .reasons-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 0.75rem;
        margin-bottom: 2rem;
    }

    .reason-card {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.875rem;
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
    }

    .reason-icon {
        font-size: 1.25rem;
    }

    .reason-content {
        display: flex;
        flex-direction: column;
    }

    .reason-count {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--ink);
    }

    .reason-label {
        font-size: 0.7rem;
        color: var(--ink-3);
    }

    /* Subsections */
    .seminal-section,
    .top-citations-section,
    .trend-section {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--rule);
    }

    .subsection-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1rem;
        font-weight: 600;
        margin: 0 0 1rem;
        color: var(--ink);
    }

    .subsection-icon {
        font-size: 1rem;
    }

    .help-text {
        font-size: 0.75rem;
        color: var(--ink-3);
        font-weight: 400;
        margin-left: auto;
    }

    /* Citations List */
    .citations-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .citations-list.compact {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
    }

    .citation-card {
        background: var(--paper-2);
        border: 1px solid var(--rule);
        border-radius: var(--r-3);
        padding: 1.25rem;
        transition: all 0.2s ease;
    }

    .citation-card:hover {
        background: var(--paper-3);
        border-color: var(--rule-strong);
    }

    .citation-card.seminal {
        border-left: 3px solid var(--aged-gold);
    }

    .citation-card.compact {
        padding: 1rem;
    }

    .citation-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .impact-badge {
        padding: 2px 8px;
        border-radius: var(--r-pill);
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .impact-badge.seminal {
        background: rgba(255, 215, 0, 0.15);
        color: var(--aged-gold);
    }

    .impact-badge.significant {
        background: rgba(16, 185, 129, 0.15);
        color: var(--verdant);
    }

    .impact-badge.supporting {
        background: rgba(59, 130, 246, 0.15);
        color: var(--ink-blue);
    }

    .impact-badge.minor {
        background: rgba(107, 114, 128, 0.15);
        color: #9ca3af;
    }

    .impact-badge.small {
        padding: 1px 6px;
        font-size: 0.6rem;
    }

    .citation-year {
        font-size: 0.75rem;
        color: var(--ink-3);
        margin-left: auto;
    }

    .citing-paper {
        font-size: 0.9rem;
        color: var(--ink-2);
        margin: 0 0 0.75rem;
        line-height: 1.5;
    }

    .citation-context {
        margin: 0.75rem 0;
        padding: 0.75rem 1rem;
        background: var(--paper-3);
        border-left: 2px solid rgba(255, 215, 0, 0.3);
        font-size: 0.85rem;
        font-style: italic;
        color: var(--ink-2);
        line-height: 1.6;
    }

    .citation-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .reason-tag {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 3px 8px;
        background: var(--paper-3);
        border-radius: 4px;
        font-size: 0.7rem;
        color: var(--ink-2);
    }

    .reason-tag.small {
        padding: 2px 6px;
        font-size: 0.85rem;
    }

    .journal-name {
        font-size: 0.75rem;
        color: var(--ink-3);
    }

    /* Trend Bars */
    .trend-bars {
        display: flex;
        align-items: flex-end;
        gap: 0.5rem;
        height: 120px;
        padding-top: 1rem;
    }

    .trend-bar-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        height: 100%;
    }

    .trend-bar {
        width: 100%;
        max-width: 40px;
        background: linear-gradient(to top, rgba(245, 158, 11, 0.3), rgba(245, 158, 11, 0.6));
        border-radius: 4px 4px 0 0;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        position: relative;
        transition: all 0.3s ease;
    }

    .trend-bar:hover {
        background: linear-gradient(to top, rgba(245, 158, 11, 0.4), rgba(245, 158, 11, 0.8));
    }

    .bar-value {
        position: absolute;
        top: -1.5rem;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--ink-2);
    }

    .bar-year {
        font-size: 0.65rem;
        color: var(--ink-3);
        margin-top: 0.5rem;
    }

    /* Tier colors */
    .tier-titan .section-title svg { color: var(--aged-gold); }
    .tier-elite .section-title svg { color: var(--ink-blue); }
    .tier-master .section-title svg { color: var(--verdant); }

    @media (max-width: 768px) {
        .citation-context-section {
            padding: 1.5rem;
        }

        .reasons-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .citations-list.compact {
            grid-template-columns: 1fr;
        }

        .trend-bars {
            height: 80px;
        }
    }
</style>
